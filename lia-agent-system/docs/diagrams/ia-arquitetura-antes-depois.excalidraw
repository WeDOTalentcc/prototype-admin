    {
      "type": "text",
      "id": "depois_evidence_1_txt",
      "x": 1050, "y": 1108,
      "width": 430, "height": 120,
      "text": "# ToolProtocol — contrato declarativo (DEPOIS)\nfrom typing import Protocol\n\nclass ToolProtocol(Protocol):\n    name: str\n    description: str\n    allowed_agents: list[str]\n    scope: PromptScope\n    async def execute(self, **kwargs) -> ToolResult: ...\n# sem acoplamento por string — validado no import",
      "originalText": "# ToolProtocol — contrato declarativo (DEPOIS)\nfrom typing import Protocol\n\nclass ToolProtocol(Protocol):\n    name: str\n    description: str\n    allowed_agents: list[str]\n    scope: PromptScope\n    async def execute(self, **kwargs) -> ToolResult: ...\n# sem acoplamento por string — validado no import",
