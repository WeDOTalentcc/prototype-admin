    {
      "type": "text",
      "id": "depois_evidence_2_txt",
      "x": 1520, "y": 1108,
      "width": 440, "height": 120,
      "text": "# UnifiedOrchestrator — DI explícita (DEPOIS)\nclass UnifiedOrchestrator:\n    def __init__(\n        self,\n        llm: LLMProviderABC,        # FIX #7\n        action_registry: ActionRegistryProtocol,  # FIX #3\n        fairness_guard: FairnessGuard,  # FIX #6: 1x\n    ): ...\n# flag USE_LANGGRAPH_NATIVE removida — LangGraph unico, sem fallback",
      "originalText": "# UnifiedOrchestrator — DI explícita (DEPOIS)\nclass UnifiedOrchestrator:\n    def __init__(\n        self,\n        llm: LLMProviderABC,        # FIX #7\n        action_registry: ActionRegistryProtocol,  # FIX #3\n        fairness_guard: FairnessGuard,  # FIX #6: 1x\n    ): ...\n# flag USE_LANGGRAPH_NATIVE removida — LangGraph unico, sem fallback",
