[run]
source = app
omit =
    app/domains/job_management/services/wizard_step_service.py
    app/domains/sourcing/tools.py
    app/domains/communication/services/email_providers.py
    app/tests/*

[report]
exclude_lines =
    if TYPE_CHECKING:
    if __name__ == "__main__":
    raise NotImplementedError
    \.\.\.
