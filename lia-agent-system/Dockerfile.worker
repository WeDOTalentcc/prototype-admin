# ==============================================================================
# Dockerfile.worker — LIA Celery Worker (Cloud Run Job / separate service)
# Multi-stage build: builder + runtime (non-root, minimal attack surface)
#
# Entrypoint: celery -A app.core.celery_app worker
#
# Filas disponíveis (configuradas em lia_config/celery_app.py):
#   sourcing_high     — busca de candidatos (SLA curto, priority=8)
#   evaluation_normal — WSI, scoring, triagem (priority=5)
#   vagas_normal      — operações de vaga (priority=5)
#   onboarding_low    — comunicações, reports (priority=3)
#
# Variáveis de ambiente obrigatórias:
#   REDIS_URL           — Broker/backend (ex: redis://:password@host:6379/0)
#   DATABASE_URL        — PostgreSQL connection string
#   ANTHROPIC_API_KEY   — Claude API key
#   OPENAI_API_KEY      — OpenAI API key (opcional)
#
# Variáveis de ambiente opcionais:
#   CELERY_QUEUES       — Filas que este worker consome (padrão: todas)
#   CELERY_CONCURRENCY  — Nº de workers paralelos (padrão: 2 para Cloud Run)
#   CELERY_LOGLEVEL     — Nível de log (padrão: info)
#   BROKER_BACKEND      — redis | rabbitmq | pubsub (padrão: redis)
#   CELERY_BROKER_URL   — URL explícita para o broker (sobrepõe BROKER_BACKEND)
#   CELERY_RESULT_BACKEND — URL explícita para o result backend
# ==============================================================================

# ── Stage 1: builder ──────────────────────────────────────────────────────────
FROM python:3.11-slim AS builder

WORKDIR /build

# Build deps only (won't be in final image)
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

# Copy source for internal libs
COPY libs/ libs/
RUN pip install --no-cache-dir --prefix=/install \
    libs/config \
    libs/utils \
    libs/audit \
    libs/messaging \
    libs/models \
    libs/agents-core \
    libs/services \
    libs/contexts \
    libs/auth


# ── Stage 2: runtime ──────────────────────────────────────────────────────────
FROM python:3.11-slim AS runtime

# Runtime OS deps only
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Non-root user (security hardening)
RUN useradd --no-create-home --no-log-init --uid 1001 appuser

WORKDIR /app

# Copy installed packages from builder
COPY --from=builder /install /usr/local

# Copy application source
COPY --chown=appuser:appuser . .

# Drop root
USER appuser

# Health check — verifica que o worker está vivo (ping ao broker)
HEALTHCHECK --interval=60s --timeout=15s --start-period=30s --retries=3 \
    CMD celery -A app.core.celery_app inspect ping --timeout=10 || exit 1

# Celery worker with HTTP health wrapper for Cloud Run.
# The health server responds on $PORT so Cloud Run readiness checks pass.
# Celery consumes all queues by default.
# To restrict: docker run -e CELERY_QUEUES=sourcing_high,evaluation_normal ...
CMD ["python3", "scripts/worker_health.py"]
