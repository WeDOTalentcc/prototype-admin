# ============================================================================
# mypy.strict.ini.proposed — PROPOSTA, não-ativo ainda (2026-05-20)
# ============================================================================
# Status: PROPOSTA. NÃO renomear para mypy.ini sem aprovação do Paulo + sprint
# dedicada de cleanup. Pyproject.toml [tool.mypy] continua sendo o config ativo.
#
# Para testar este config localmente sem ativar globalmente:
#   python -m mypy --config-file mypy.strict.ini.proposed app/
#
# Para usar este config como ativo (depois de sprint cleanup):
#   mv mypy.strict.ini.proposed mypy.ini
#   # (mypy.ini tem precedência sobre pyproject.toml [tool.mypy])
#
# Baseline 2026-05-20 com este config esperado:
#   - Strict global + ignore_errors em legacy modules (top 50 erros) → ~0 errors
#   - Permite ratchet: cada módulo migrado remove sua entrada do bloco
#     ignore_errors[]. Nunca regride.
# ============================================================================

[mypy]
python_version = 3.11
strict = True
ignore_missing_imports = True
warn_unused_configs = True
warn_unused_ignores = True
warn_redundant_casts = True
namespace_packages = True
explicit_package_bases = True
exclude = (?x)(
    ^tests/
    | ^migrations/
    | ^scripts/
    | ^app/tests/
    | ^app/migrations/
    )
plugins = pydantic.mypy

[pydantic-mypy]
init_forbid_extra = True
init_typed = True
warn_required_dynamic_aliases = True

# ============================================================================
# Módulos canonical strict-clean (mantém strict, zero new errors permitidos)
# ============================================================================
# Auditados 2026-05-20: 0 erros em --strict standalone.

[mypy-app.shared.types]
strict = True

[mypy-app.enums.*]
strict = True

[mypy-app.contracts.*]
strict = True

[mypy-app.core.config]
strict = True

[mypy-app.core.celery_app]
strict = True

[mypy-app.core.tenant]
strict = True

[mypy-app.config.*]
strict = True

[mypy-app.constants.*]
strict = True

