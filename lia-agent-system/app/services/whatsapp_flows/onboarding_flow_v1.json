{
  "version": "3.0",
  "screens": [
    {
      "id": "SCREEN_HIRING_FOCUS",
      "title": "Seu foco de contratacao",
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Qual e o seu foco principal?"
          },
          {
            "type": "RadioButtonsGroup",
            "name": "hiring_focus",
            "required": true,
            "data-source": [
              {"id": "tech", "title": "Vagas tecnicas (tech)"},
              {"id": "operations", "title": "Vagas operacionais"},
              {"id": "executive", "title": "Vagas executivas"},
              {"id": "volume", "title": "Volume alto (100+ vagas)"},
              {"id": "mixed", "title": "Misto"}
            ]
          },
          {
            "type": "Footer",
            "label": "Proximo",
            "on-click-action": {
              "name": "navigate",
              "next": {"type": "screen", "name": "SCREEN_VOLUME"}
            }
          }
        ]
      }
    },
    {
      "id": "SCREEN_VOLUME",
      "title": "Volume mensal",
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Quantas vagas voce gerencia por mes?"
          },
          {
            "type": "RadioButtonsGroup",
            "name": "monthly_volume",
            "required": true,
            "data-source": [
              {"id": "1-5", "title": "1 a 5"},
              {"id": "6-15", "title": "6 a 15"},
              {"id": "16-30", "title": "16 a 30"},
              {"id": "30+", "title": "Mais de 30"}
            ]
          },
          {
            "type": "Footer",
            "label": "Proximo",
            "on-click-action": {
              "name": "navigate",
              "next": {"type": "screen", "name": "SCREEN_PAIN"}
            }
          }
        ]
      }
    },
    {
      "id": "SCREEN_PAIN",
      "title": "Maior desafio",
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "O que mais te toma tempo hoje?"
          },
          {
            "type": "CheckboxGroup",
            "name": "biggest_pain",
            "required": true,
            "min-selected-items": 1,
            "max-selected-items": 3,
            "data-source": [
              {"id": "screening", "title": "Triagem de curriculos"},
              {"id": "jd_creation", "title": "Criar descricoes de vaga"},
              {"id": "scheduling", "title": "Agendar entrevistas"},
              {"id": "sourcing", "title": "Buscar candidatos"},
              {"id": "reports", "title": "Relatorios para gestores"}
            ]
          },
          {
            "type": "Footer",
            "label": "Proximo",
            "on-click-action": {
              "name": "navigate",
              "next": {"type": "screen", "name": "SCREEN_CONSENT"}
            }
          }
        ]
      }
    },
    {
      "id": "SCREEN_CONSENT",
      "title": "Consentimento",
      "terminal": true,
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Quase pronto!"
          },
          {
            "type": "TextBody",
            "text": "Seus dados serao usados pela LIA para personalizar sua experiencia de recrutamento, conforme a LGPD (Lei 13.709/2018). Voce pode solicitar exclusao a qualquer momento."
          },
          {
            "type": "OptIn",
            "name": "lgpd_consent",
            "required": true,
            "label": "Autorizo o processamento dos meus dados conforme a LGPD"
          },
          {
            "type": "Footer",
            "label": "Finalizar",
            "on-click-action": {
              "name": "complete",
              "payload": {}
            }
          }
        ]
