# =============================================
# LIA Agent System - Environment Variables
# =============================================

# Application
APP_NAME=lia-agent-system
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8001
CORS_ORIGINS=["http://localhost:5000","http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@helium/heliumdb
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# =============================================
# LLM PROVIDERS
# =============================================

# Claude (Primary) - COLE SUA API KEY AQUI
ANTHROPIC_API_KEY=

# OpenAI (Fallback) - Opcional por enquanto
OPENAI_API_KEY=

# Google Gemini (Future)
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=

# LangSmith (Observability) - Opcional por enquanto
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=lia-agent-system

# =============================================
# EXTERNAL INTEGRATIONS (Desabilitado por enquanto)
# =============================================

# Pearch AI
PEARCH_API_KEY=
PEARCH_API_URL=https://api.pearch.ai

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Microsoft Graph
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# =============================================
# JIRA / BUG SPEC GENERATOR
# =============================================
# Gere seu API Token em: https://id.atlassian.com/manage-api-tokens
JIRA_EMAIL=
JIRA_API_TOKEN=

# =============================================
# SECURITY
# =============================================

# JWT
SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================
# FEATURE FLAGS
# =============================================

ENABLE_PEARCH_AI=false
ENABLE_TWILIO=false
ENABLE_MICROSOFT_GRAPH=true

# =============================================
# COMPLIANCE / FAIRNESS
# =============================================

# FairnessGuard Camada 3 — verificação semântica via LLM (~2s de latência adicional)
# Recomendado: false em dev, true em produção após homologação de latência
FAIRNESS_LAYER3_ENABLED=true

# =============================================
# FASE 1 — AUDIT STORAGE (AuditCallback + Dual Storage)
# =============================================

# "file" em dev, "s3" em produção
AUDIT_STORAGE_TYPE=file
AUDIT_LOCAL_DIR=./audit_logs

# S3 — obrigatório quando AUDIT_STORAGE_TYPE=s3
AUDIT_STORAGE_BUCKET=
AUDIT_STORAGE_PREFIX=audit
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# =============================================
# FASE 2 — COST CASCADE ORCHESTRATOR
# =============================================

# Modelos por tier
LLM_ROUTER_MODEL=claude-haiku-4-5-20251001
LLM_AGENT_MODEL=claude-sonnet-4-6

# Thresholds de confiança para cascade Haiku → Sonnet → Opus
LLM_CASCADE_FAST_THRESHOLD=0.80
LLM_CASCADE_MID_THRESHOLD=0.70
LLM_CASCADE_FALLBACK_THRESHOLD=0.60

# Cache
ROUTER_CACHE_TTL=3600
SEMANTIC_CACHE_TTL=86400

# Budget por tenant (tokens/mês)
TENANT_TOKEN_BUDGET_DEFAULT=500000
TENANT_TOKEN_BUDGET_ALERT_THRESHOLD=0.80

# =============================================
# FASE 3 — LANGGRAPH NATIVE (migração gradual)
# =============================================

# Feature flag — ativado em produção (Fase 1 Gaps, 08/03/2026)
# false = path legado ReActLoop (rollback de emergência)
USE_LANGGRAPH_NATIVE=true

# =============================================
# FASE 4 — WEBSOCKET / MESSAGING
# =============================================

RABBITMQ_EXCHANGE=rh_platform
RABBITMQ_PREFETCH=1
WS_MAX_CONNECTIONS_PER_TENANT=100

# =============================================
# FASE 5 — CONFIG PROVIDER
# =============================================

# "env" em dev, "doppler" em produção
SECRETS_PROVIDER=env
DOPPLER_TOKEN=

# Microsoft Teams Bot
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
MICROSOFT_TENANT_ID=
TEAMS_WEBHOOK_URL=

# Tier 3: Semantic vector cache (pgvector)
ROUTER_VECTOR_CACHE_ENABLED=true
LIA_DEV_MODE=1
FIELD_ENCRYPTION_KEY=dqrbTw5qhM69otI0Rr7RqoFrR-1NsIKd7Ou8RhdHMrM=

# Plan & Execute (Sprint 1 — UC-P3-14)
LIA_V2_USE_PLAN_SERVICE=true
LIA_V2_USE_FALLBACK_REACT=true

# =============================================
# HARNESS FIX (2026-05-19) — Tenant Context Leak (regressão B1)
# =============================================
# REGRA: bug \"wizard pede company_id/consultor\" deve ser VISÍVEL em dev,
# não silenciosamente degradado para fail-OPEN (que mascara o leak).
# Source-of-truth: docs/architecture/wizard-flow.md §11.1 + runbook
# docs/runbooks/missing_tenant_context.md.
LIA_AGENT_TENANT_STRICT=true
LIA_WIZARD_FALLBACK_LLM_DISABLED=1
