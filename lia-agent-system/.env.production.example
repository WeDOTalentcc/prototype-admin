# =============================================
# LIA Agent System — Production Environment
# =============================================
# Copy to .env on the production host or inject via Secret Manager.
# Lines marked [REQUIRED] must be set. Lines marked [OPTIONAL] have sane defaults.
# =============================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=lia-agent-system                         # [OPTIONAL]
APP_ENV=production                                # [REQUIRED] must be "production"
DEBUG=False                                       # [REQUIRED] must be False
LOG_LEVEL=WARNING                                 # [OPTIONAL] INFO in staging
APP_VERSION=3.0.0                                 # [OPTIONAL]
APP_BASE_URL=https://wedotalent.cc                # [REQUIRED] public URL for links/webhooks

# ── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0                                  # [OPTIONAL]
API_PORT=8000                                     # [OPTIONAL] Cloud Run uses PORT env var
CORS_ORIGINS=["https://wedotalent.cc","https://www.wedotalent.cc"]  # [REQUIRED]

# ── Database (Cloud SQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://lia_user:PASSWORD@/lia_db?host=/cloudsql/PROJECT:REGION:INSTANCE  # [REQUIRED]
DATABASE_POOL_SIZE=20                             # [OPTIONAL]
DATABASE_MAX_OVERFLOW=10                          # [OPTIONAL]

# ── Redis (Memorystore) ─────────────────────────────────────────────────────
REDIS_URL=redis://:PASSWORD@MEMORYSTORE_IP:6379/0 # [REQUIRED] supports auth via URL
ROUTER_CACHE_TTL=3600                             # [OPTIONAL]
SEMANTIC_CACHE_TTL=86400                          # [OPTIONAL]

# ── Messaging (Celery broker) ────────────────────────────────────────────────
BROKER_BACKEND=redis                              # [OPTIONAL] "redis" | "pubsub"
CELERY_BROKER_URL=                                # [OPTIONAL] falls back to REDIS_URL
CELERY_RESULT_BACKEND=                            # [OPTIONAL] falls back to REDIS_URL

# ── Security / Auth ──────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64  # [REQUIRED] JWT signing
ALGORITHM=HS256                                   # [OPTIONAL]
ACCESS_TOKEN_EXPIRE_MINUTES=30                    # [OPTIONAL]
ADMIN_API_KEY=                                    # [OPTIONAL] for /admin/* endpoints

# ── WorkOS SSO ───────────────────────────────────────────────────────────────
WORKOS_CLIENT_ID=                                 # [REQUIRED] for SSO login
WORKOS_API_KEY=                                   # [REQUIRED] for SSO login
WORKOS_WEBHOOK_SECRET=                            # [OPTIONAL] for WorkOS webhooks

# ── LLM Providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                                # [REQUIRED] Claude (primary)
OPENAI_API_KEY=                                   # [OPTIONAL] fallback
GOOGLE_CLOUD_PROJECT=                             # [REQUIRED] for Gemini via Vertex AI
GOOGLE_CLOUD_REGION=us-east1                      # [OPTIONAL]
# GOOGLE_APPLICATION_CREDENTIALS is NOT needed on Cloud Run — Workload Identity provides credentials automatically.

LLM_PRIMARY_MODEL=claude-sonnet-4-6              # [OPTIONAL]
LLM_FAST_MODEL=gemini-2.5-flash                  # [OPTIONAL]
LLM_AGENT_MODEL=claude-sonnet-4-6                # [OPTIONAL]
LLM_ROUTER_MODEL=gemini-2.5-flash                # [OPTIONAL]
LLM_DEFAULT_PROVIDER=gemini                       # [OPTIONAL]

# ── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=                                       # [REQUIRED] error tracking
SENTRY_TRACES_SAMPLE_RATE=0.1                     # [OPTIONAL]

# ── Twilio (Voice + WhatsApp) ────────────────────────────────────────────────
ENABLE_TWILIO=true                                # [REQUIRED]
TWILIO_ACCOUNT_SID=                               # [REQUIRED] if ENABLE_TWILIO=true
TWILIO_AUTH_TOKEN=                                # [REQUIRED] if ENABLE_TWILIO=true
TWILIO_VOICE_NUMBER=+551150289337                 # [REQUIRED] E.164 format
TWILIO_WHATSAPP_NUMBER=whatsapp:+551150289337     # [OPTIONAL] pending Meta approval
TWILIO_WEBHOOK_BASE_URL=https://wedotalent.cc     # [REQUIRED] for TwiML callback URLs
TWILIO_TWIML_APP_SID=                             # [OPTIONAL] for VoIP browser calls

# ── Microsoft Graph (Calendar) ───────────────────────────────────────────────
ENABLE_MICROSOFT_GRAPH=true                       # [OPTIONAL]
AZURE_TENANT_ID=                                  # [REQUIRED] if calendar enabled
AZURE_CLIENT_ID=                                  # [REQUIRED] if calendar enabled
AZURE_CLIENT_SECRET=                              # [REQUIRED] if calendar enabled

# ── Microsoft Teams Bot ──────────────────────────────────────────────────────
MICROSOFT_APP_ID=                                 # [OPTIONAL]
MICROSOFT_APP_PASSWORD=                           # [OPTIONAL]
TEAMS_APP_TENANT_ID=                              # [OPTIONAL]
TEAMS_WEBHOOK_URL=https://wedotalent.cc/api/v1/teams/webhook  # [OPTIONAL]

# ── Email (Mailgun + Resend fallback) ────────────────────────────────────────
MAILGUN_API_KEY=                                  # [REQUIRED] for email sending
MAILGUN_DOMAIN=mg.wedotalent.com                  # [REQUIRED]
RESEND_API_KEY=                                   # [OPTIONAL] fallback
EMAIL_FROM_ADDRESS=noreply@wedotalent.com          # [OPTIONAL]
EMAIL_FROM_NAME=WeDOTalent                         # [OPTIONAL]

# ── Stripe Billing ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                                # [OPTIONAL]
STRIPE_WEBHOOK_SECRET=                            # [OPTIONAL]
STRIPE_PUBLISHABLE_KEY=                           # [OPTIONAL]

# ── Audit Storage ────────────────────────────────────────────────────────────
AUDIT_STORAGE_TYPE=s3                             # [REQUIRED] "s3" in production
AUDIT_STORAGE_BUCKET=lia-audit-logs               # [REQUIRED] when type=s3
AUDIT_STORAGE_PREFIX=audit                        # [OPTIONAL]
S3_REGION=us-east-1                               # [OPTIONAL]
# S3_ACCESS_KEY and S3_SECRET_KEY not needed on GCP — use Workload Identity

# ── Observability ────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true                         # [OPTIONAL]
LANGCHAIN_API_KEY=                                # [OPTIONAL] LangSmith
LANGCHAIN_PROJECT=lia-agent-system                # [OPTIONAL]

OTEL_SERVICE_NAME=lia-agent-system                # [OPTIONAL]
OTEL_EXPORTER_OTLP_ENDPOINT=                      # [OPTIONAL] empty = disabled

# ── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_PEARCH_AI=false                            # [OPTIONAL]
ENABLE_GOOGLE_CALENDAR=false                      # [OPTIONAL]
FAIRNESS_LAYER3_ENABLED=true                      # [RECOMMENDED] in production
FAIRNESS_TOOL_CHECK_ENABLED=true                  # [RECOMMENDED]
LGPD_CONSENT_ABSENT_HARD_BLOCK=true               # [RECOMMENDED] strict LGPD in production
USE_LANGGRAPH_NATIVE=true                         # [OPTIONAL]
PLAN_LIMITS_ENFORCE=true                          # [RECOMMENDED]

# ── Secrets Provider ─────────────────────────────────────────────────────────
SECRETS_PROVIDER=env                              # [OPTIONAL] "env" | "doppler"
DOPPLER_TOKEN=                                    # [OPTIONAL] if provider=doppler

# ── Gunicorn (Dockerfile.prod) ───────────────────────────────────────────────
GUNICORN_WORKERS=4                                # [OPTIONAL] Cloud Run: 2–4
PORT=8000                                         # [OPTIONAL] Cloud Run sets this

# ── Celery Worker (Dockerfile.worker) ────────────────────────────────────────
CELERY_CONCURRENCY=2                              # [OPTIONAL]
CELERY_LOGLEVEL=info                              # [OPTIONAL]
CELERY_QUEUES=sourcing_high,evaluation_normal,vagas_normal,onboarding_low  # [OPTIONAL]
