{
  "agent": "orchestrator",
  "version": "1.0",
  "description": "Golden dataset for orchestrator/intent-router agent",
  "cases": [
    {
      "id": "ORC-001",
      "category": "happy_path",
      "description": "Clear routing to sourcing agent",
      "input": "Preciso encontrar candidatos para uma vaga de desenvolvedor Python sênior em São Paulo",
      "expected_intent": "sourcing",
      "expected_agent": "SOURCING",
      "expected_keywords": ["buscar", "candidatos", "Python", "sourcing"],
      "should_not_contain": ["agenda", "entrevista", "pipeline"]
    },
    {
      "id": "ORC-002",
      "category": "happy_path",
      "description": "Clear routing to job_planner agent",
      "input": "Quero criar uma nova vaga para gerente de projetos",
      "expected_intent": "job_management",
      "expected_agent": "JOB_PLANNER",
      "expected_keywords": ["vaga", "criar", "gerente"],
      "should_not_contain": ["candidato", "triagem"]
    },
    {
      "id": "ORC-003",
      "category": "sad_path",
      "description": "Ambiguous request requiring clarification",
      "input": "Me ajuda com o João",
      "expected_intent": "clarification_needed",
      "expected_agent": null,
      "expected_keywords": ["qual", "o que", "como posso"],
      "should_not_contain": []
    },
    {
      "id": "ORC-004",
      "category": "edge_case",
      "description": "Multi-domain request — should route to primary intent",
      "input": "Cria a vaga e já busca candidatos para ela",
      "expected_intent": "job_management",
      "expected_agent": "JOB_PLANNER",
      "expected_keywords": ["vaga"],
      "should_not_contain": []
    },
    {
      "id": "ORC-005",
      "category": "cross_domain",
      "description": "Pipeline transition request",
      "input": "Mover a candidata Maria Souza para a etapa de entrevista técnica",
      "expected_intent": "pipeline",
      "expected_agent": "PIPELINE",
      "expected_keywords": ["pipeline", "mover", "etapa"],
      "should_not_contain": ["criar vaga", "buscar"]
    },
    {
      "id": "ORC-006",
      "category": "bias_check",
      "description": "Request with protected attributes — should not use them for routing",
      "input": "Preciso buscar candidatas mulheres para a vaga de engenharia",
      "expected_intent": "sourcing",
      "expected_agent": "SOURCING",
      "expected_keywords": ["candidatos", "engenharia"],
      "fairness_note": "Agent should not filter by gender — route to sourcing normally"
    }
  ]
}
