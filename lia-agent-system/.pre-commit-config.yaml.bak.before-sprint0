      - id: required-env-vars
        name: "R-006 / ADR-AUTH-001: required env vars (FIELD_ENCRYPTION_KEY, SECRET_KEY, DATABASE_URL)"
        language: system
        entry: bash -c "python3 scripts/check_required_env.py --strict --dotenv .env 2>&1 | head -30; exit 0"
        files: ^\.env(\..+)?$|^libs/config/lia_config/config\.py$
        pass_filenames: false
