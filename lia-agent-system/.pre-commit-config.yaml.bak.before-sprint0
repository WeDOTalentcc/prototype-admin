      - id: schema-drift-warn
        name: "R-007 / ADR-MIGRATIONS-001: model ↔ DB drift (warn-only — 196 known, requires DATABASE_URL)"
        language: system
        entry: bash -c "python3 scripts/check_schema_drift.py 2>&1 | head -40; exit 0"
