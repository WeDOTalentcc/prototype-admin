repos:
  # ── Ruff: linting + formatting ──────────────────────────────────────────────
  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: v0.4.4
    hooks:
      - id: ruff
        args: [--fix, --exit-non-zero-on-fix]
        exclude: ^(tests/|migrations/)
      - id: ruff-format
        exclude: ^(tests/|migrations/)

  # ── mypy: static type checking (warn-only during gradual adoption) ───────────
  # Non-blocking wrapper: runs mypy and prints diagnostics but always exits 0.
  # Remove the '|| true' suffix when ready to enforce (planned: after full type coverage).
  - repo: local
    hooks:
      - id: mypy-warn-only
        name: mypy (type check — warn only, non-blocking)
        language: system
        entry: bash -c 'python3 -m mypy app/ --ignore-missing-imports --no-error-summary --config-file=pyproject.toml 2>&1 || true'
        pass_filenames: false
        always_run: false
        files: ^app/.*\.py$

  # ── Local guardrails ─────────────────────────────────────────────────────────
  - repo: local
    hooks:
      - id: no-sql-in-controllers
        name: "G1: No SQL in API controllers"
        language: python
        entry: python3 scripts/check_no_sql_in_controllers.py
        files: ^app/api/.*\.py$
        pass_filenames: false
        always_run: false

      - id: no-pii-in-logs
        name: "G4: No PII in log calls (LGPD)"
        language: python
        entry: python3 scripts/check_no_pii_in_logs.py
        files: ^app/.*\.py$
        pass_filenames: false
        always_run: false
        exclude: ^(tests/|scripts/)

      - id: response-model-required
        name: "G2: response_model required on all endpoints"
        language: python
        entry: python3 scripts/check_response_models.py
        files: ^app/api/.*\.py$
        pass_filenames: false
        always_run: false

      - id: tenant-db-required
        name: "G-TENANTDB: Depends(get_tenant_db) required in app/domains/"
        language: python
        entry: python3 scripts/check_tenant_db.py
        files: ^app/domains/.*\.py$
        pass_filenames: false
        always_run: false

      - id: no-tenant-in-tool-schemas
        name: "ADR-029 §2: tool schemas must not expose tenant keys to LLM (BLOCKING)"
        language: system
        entry: python3 scripts/check_no_tenant_in_tool_schemas.py --block
        files: ^app/(domains|shared|tools)/.*\.py$
        pass_filenames: false
        always_run: false

      - id: no-devmode-in-prod-env
        name: "G-DEVMODE: block LIA_DEV_MODE active in .env.staging/.env.production (BLOCKING)"
        language: system
        entry: python3 scripts/check_no_devmode_in_prod_env.py
        files: ^(\.env\.|\.env$|app/).*
        pass_filenames: false
        always_run: false

      - id: company-id-in-routes-warn
        name: "Multi-tenancy: routes must call _require_company_id (warn-only)"
        language: system
        entry: bash -c "python3 scripts/check_company_id_in_routes.py 2>&1; exit 0"
        files: ^app/api/v1/.*\.py$
        pass_filenames: false
        always_run: false

      - id: no-direct-contextvar-set-warn
        name: "G-CONTEXTVAR: bloquear set direto fora dos helpers R-008 (warn-only)"
        language: system
        entry: bash -c "python3 scripts/check_no_direct_contextvar_set.py 2>&1; exit 0"
        files: ^app/.*\.py$
        pass_filenames: false
        always_run: false

      - id: no-cid-empty-escape
        name: "Multi-tenancy: SQL escape  cid empty OR  forbidden (BLOCKING)"
        language: system
        entry: python3 scripts/check_no_cid_empty_escape.py
        files: ^app/.*\.py$
        pass_filenames: false
        always_run: false

      - id: table-has-rls-policy
        name: "ADR-030 v2: tables with company_id should have RLS migration (warn-only)"
        language: system
        entry: bash -c "python3 scripts/check_table_has_rls_policy.py 2>&1 | head -5; exit 0"
        files: ^(libs/models/lia_models/.*\.py|alembic/versions/.*\.py)$
        pass_filenames: false
        always_run: false

      - id: agent-compliance-warn
        name: "G7: agent canonical anatomy (warn-only)"
        language: system
        entry: bash -c "python3 scripts/check_agent_compliance.py 2>&1; exit 0"
        files: ^app/domains/.*react_agent\.py$
