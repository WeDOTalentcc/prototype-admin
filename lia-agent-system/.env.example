# =============================================
# LIA Agent System - Environment Variables
# =============================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite .env (já está no .gitignore).
# =============================================

# Application
APP_NAME=lia-agent-system
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8001
CORS_ORIGINS=["http://localhost:5000","http://localhost:3000"]

# Rails ATS API (ats-api-copia — vagas, candidatos, processos seletivos)
RAILS_API_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://lia_user:lia_password@localhost:5432/lia_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# =============================================
# LLM PROVIDERS
# =============================================

# Claude (Primary)
ANTHROPIC_API_KEY=your_claude_api_key_here

# OpenAI (Fallback)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini (Future)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your_project_id

# LangSmith (Observability)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=lia-agent-system

# =============================================
# EXTERNAL INTEGRATIONS
# =============================================

# Pearch AI
PEARCH_API_KEY=your_pearch_api_key_here
PEARCH_API_URL=https://api.pearch.ai

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Microsoft Graph
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret

# =============================================
# JIRA / BUG SPEC GENERATOR
# =============================================
# Gere seu API Token em: https://id.atlassian.com/manage-api-tokens
JIRA_EMAIL=seu@email.com
JIRA_API_TOKEN=seu_token_aqui
JIRA_CLOUD_ID=8cf762f8-6a44-47de-8915-6b3dc0cd2715
JIRA_PROJECT=WT

# =============================================
# SECURITY
# =============================================

# JWT
SECRET_KEY=your_super_secret_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================
# FEATURE FLAGS
# =============================================

ENABLE_PEARCH_AI=false
ENABLE_TWILIO=false
ENABLE_MICROSOFT_GRAPH=true

# =============================================
# COMPLIANCE / FAIRNESS
# =============================================

# FairnessGuard Camada 3 — verificação semântica via LLM (~2s de latência adicional)
# Recomendado: false em dev, true em produção após homologação de latência
FAIRNESS_LAYER3_ENABLED=false

# =============================================
# FASE 1 — AUDIT STORAGE (AuditCallback + Dual Storage)
# =============================================

# "file" em dev, "s3" em produção
AUDIT_STORAGE_TYPE=file
AUDIT_LOCAL_DIR=./audit_logs

# S3 — obrigatório quando AUDIT_STORAGE_TYPE=s3
AUDIT_STORAGE_BUCKET=your-audit-bucket
AUDIT_STORAGE_PREFIX=audit
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_REGION=us-east-1

# =============================================
# FASE 2 — COST CASCADE ORCHESTRATOR
# =============================================

# Modelos por tier
LLM_ROUTER_MODEL=claude-haiku-4-5-20251001
LLM_AGENT_MODEL=claude-sonnet-4-6

# Thresholds de confiança para cascade Haiku → Sonnet → Opus
LLM_CASCADE_FAST_THRESHOLD=0.80
LLM_CASCADE_MID_THRESHOLD=0.70
LLM_CASCADE_FALLBACK_THRESHOLD=0.60

# Cache
ROUTER_CACHE_TTL=3600
SEMANTIC_CACHE_TTL=86400

# Budget por tenant (tokens/mês)
TENANT_TOKEN_BUDGET_DEFAULT=500000
TENANT_TOKEN_BUDGET_ALERT_THRESHOLD=0.80

# =============================================
# FASE 3 — LANGGRAPH NATIVE (migração gradual)
# =============================================

# Feature flag — true = LangGraph nativo, false = path legado ReActLoop
USE_LANGGRAPH_NATIVE=true

# =============================================
# FASE 4 — WEBSOCKET / MESSAGING
# =============================================

RABBITMQ_EXCHANGE=rh_platform
RABBITMQ_PREFETCH=1
WS_MAX_CONNECTIONS_PER_TENANT=100

# =============================================
# FASE 5 — CONFIG PROVIDER
# =============================================

# "env" em dev, "doppler" em produção
SECRETS_PROVIDER=env
DOPPLER_TOKEN=your_doppler_token

# Microsoft Teams Bot
MICROSOFT_APP_ID=your_microsoft_app_id
MICROSOFT_APP_PASSWORD=your_microsoft_app_password
MICROSOFT_TENANT_ID=your_microsoft_tenant_id
TEAMS_WEBHOOK_URL=https://your-domain/api/v1/teams/webhook
