# =============================================
# LIA Agent System - Environment Variables
# =============================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite .env (já está no .gitignore).
# =============================================

# Application
APP_NAME=lia-agent-system
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8001
# CORS — JSON list of allowed origins (Pydantic parses this directly).
# MIGRATION_PLAN item 7.4 — production origins must include the GCP app
# domain + staging + local dev for engineering. Keep this list tight:
# each extra origin is attack surface.
#
# Examples:
#   dev      → ["http://localhost:5000","http://localhost:3000"]
#   staging  → ["https://staging.wedotalent.cc","https://staging2.wedotalent.cc"]
#   prod     → ["https://app.wedotalent.com","https://admin.wedotalent.com"]
CORS_ORIGINS=["http://localhost:5000","http://localhost:3000"]

# Rails ATS API (ats-api-copia — vagas, candidatos, processos seletivos)
# Staging: https://staging2.wedotalent.cc
# Quando configurado, RAILS_ENABLED=True automaticamente (ver _handler_hooks.py)
RAILS_API_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://lia_user:lia_password@localhost:5432/lia_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
# Task #1060: SQLAlchemy statement-level echo. Default OFF (mesmo em dev) —
# storm de logs SQL derrubava o `lia-backend` durante runs de Playwright.
# Ative APENAS quando estiver debugando query plans ou n+1 queries.
DATABASE_ECHO=False
# Override do nível dos loggers `sqlalchemy.*` (default WARNING).
# SQLALCHEMY_LOG_LEVEL=INFO

# Task #1060: cadência (em segundos) do MonitoringLoop proativo.
# Default 3600 (1h). Setar `0` desliga o loop por inteiro — usado em dev
# pra evitar varredura periódica de pipeline durante runs longos de
# Playwright. Iterações sem tenants ativos aplicam backoff exponencial
# até 8× automaticamente (sem tocar nessa flag).
# MONITORING_LOOP_INTERVAL_SECONDS=3600

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# =============================================
# LLM PROVIDERS
# =============================================

# Claude (Primary)
ANTHROPIC_API_KEY=your_claude_api_key_here

# OpenAI (Fallback)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini (Future)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your_project_id

# LangSmith — LLM call tracing (UC-P1-06; optional but recommended for prod)
# Use either LANGSMITH_API_KEY or LANGCHAIN_API_KEY (both accepted)
LANGSMITH_API_KEY=ls__xxxx
LANGSMITH_PROJECT=lia-agent-system
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=lia-agent-system

# ────────────────────────────────────────────
# Observability & Error Tracking
# ────────────────────────────────────────────

# Sentry error tracking (GAP-12-002)
# Get DSN: https://sentry.io → Settings → Projects → Client Keys
# Leave empty to disable (warn-only at startup).
SENTRY_DSN=https://...@sentry.io/...

# Datadog APM (GAP-12-003)
# Requires: ddtrace-run as entry point (see requirements.txt comment).
# Set DD_API_KEY in Replit Secrets — never commit real keys here.
DD_TRACE_ENABLED=true
DD_ENV=production
DD_SERVICE=lia-agent-system
DD_VERSION=1.0.0
DD_API_KEY=your_dd_api_key_here

# Prometheus multiprocess mode (multi-worker deployments only)
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# Memory warning threshold in % (GAP-12-011, default 80)
PSUTIL_MEMORY_WARNING_THRESHOLD=80.0

# =============================================
# EXTERNAL INTEGRATIONS
# =============================================

# Pearch AI
PEARCH_API_KEY=your_pearch_api_key_here
PEARCH_API_URL=https://api.pearch.ai

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Microsoft Graph
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret

# =============================================
# JIRA / BUG SPEC GENERATOR
# =============================================
# Gere seu API Token em: https://id.atlassian.com/manage-api-tokens
JIRA_EMAIL=seu@email.com
JIRA_API_TOKEN=seu_token_aqui
JIRA_CLOUD_ID=8cf762f8-6a44-47de-8915-6b3dc0cd2715
JIRA_PROJECT=WT

# =============================================
# SECURITY
# =============================================

# JWT
SECRET_KEY=your_super_secret_key_change_this_in_production

# At-rest field encryption (P1-W3-04/06 — webhook secrets, tenant LLM API keys, etc.)
# FIELD_ENCRYPTION_KEY — OBRIGATÓRIO em production E staging (P1-W3-06).
# Em development: se ausente, IS_DEVELOPMENT=true gera chave ephemeral (dados
# encriptados não sobrevivem restart). Para dev persistente: gere e adicione aqui.
# Sem esta key em prod/staging: RuntimeError no boot (fail-closed).
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# Redis PII Encryption (Wave 6 item 6.6)
# REDIS_ENCRYPTION_KEY — OBRIGATÓRIO em production/staging.
# Sem esta key, dados em Redis (sessions, candidate lists, fairness cache, PII)
# ficam em plaintext. App levanta RuntimeError no boot se vazio em prod (R-001).
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
REDIS_ENCRYPTION_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# External Webhook Bearer Token (P1-W3-02)
# EXTERNAL_WEBHOOK_SECRET_TOKEN — token opaco para autenticar provedores externos
# nos endpoints /external-webhooks/interview|test|document/{provider}.
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Obrigatório para que esses endpoints aceitem requisições (retorna 503 se vazio).
EXTERNAL_WEBHOOK_SECRET_TOKEN=

# =============================================
# FEATURE FLAGS
# =============================================

ENABLE_PEARCH_AI=false
ENABLE_TWILIO=false
ENABLE_MICROSOFT_GRAPH=true

# =============================================
# COMPLIANCE / FAIRNESS
# =============================================

# FairnessGuard Camada 3 — verificação semântica via LLM (~2s de latência adicional)
# Recomendado: false em dev, true em produção após homologação de latência
FAIRNESS_LAYER3_ENABLED=false

# =============================================
# FASE 1 — AUDIT STORAGE (AuditCallback + Dual Storage)
# =============================================

# "file" em dev, "s3" em produção
AUDIT_STORAGE_TYPE=file
AUDIT_LOCAL_DIR=./audit_logs

# S3 — obrigatório quando AUDIT_STORAGE_TYPE=s3
AUDIT_STORAGE_BUCKET=your-audit-bucket
AUDIT_STORAGE_PREFIX=audit
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_REGION=us-east-1

# =============================================
# FASE 2 — COST CASCADE ORCHESTRATOR
# =============================================

# Modelos por tier
LLM_ROUTER_MODEL=claude-haiku-4-5-20251001
LLM_AGENT_MODEL=claude-sonnet-4-6

# Thresholds de confiança para cascade Haiku → Sonnet → Opus
LLM_CASCADE_FAST_THRESHOLD=0.80
LLM_CASCADE_MID_THRESHOLD=0.70
LLM_CASCADE_FALLBACK_THRESHOLD=0.60

# Cache
ROUTER_CACHE_TTL=3600
SEMANTIC_CACHE_TTL=86400

# Budget por tenant (tokens/mês)
TENANT_TOKEN_BUDGET_DEFAULT=500000
TENANT_TOKEN_BUDGET_ALERT_THRESHOLD=0.80

# =============================================
# FASE 3 — LANGGRAPH NATIVE (migração gradual)
# =============================================

# Feature flag — true = LangGraph nativo, false = path legado ReActLoop
USE_LANGGRAPH_NATIVE=true

# =============================================
# FASE 4 — WEBSOCKET / MESSAGING
# =============================================

RABBITMQ_EXCHANGE=rh_platform
RABBITMQ_PREFETCH=1
WS_MAX_CONNECTIONS_PER_TENANT=100

# =============================================
# FASE 5 — CONFIG PROVIDER
# =============================================

# "env" em dev, "doppler" em produção
SECRETS_PROVIDER=env
DOPPLER_TOKEN=your_doppler_token

# =============================================
# COMPLIANCE / GOVERNANCE FLAGS
# =============================================

# ─── COMPLIANCE / EMERGENCY FLAGS (use com extremo cuidado) ──────────────
# Estas flags bypassam camadas de compliance. Apenas para rollback emergencial.
# app/main.py loga CRITICAL + Sentry capture_message no startup quando ON.
# Endpoint /api/v1/health/compliance/bypass-status expõe em runtime (canary).

# Bypass do ComplianceDomainPrompt (FairnessGuard + PII strip + PromptInjection + FactCheck)
# Set 1 apenas para rollback emergencial — desabilita gates LGPD/Fairness em domains.
LIA_ALLOW_NON_COMPLIANT_DOMAINS=0

# Bypass do LangGraphReActBase compliance em agents (PII/Fairness/Audit em agent layer)
# Set 1 apenas para rollback emergencial — desabilita gates compliance em agents.
LIA_ALLOW_NON_COMPLIANT_AGENTS=0

# KILL SWITCH da camada C3b inteira (PII strip + FairnessGuard L3 + FactChecker + AuditService)
# Set 1 para desligar completamente C3b (passthrough total) — apenas rollback emergencial.
LIA_DISABLE_C3B=0

# Permite registry com class_path inválido em prod (R-004 emergency rollback only)
# Default em prod é fail-fast no startup; set 1 para tolerar drift temporário.
LIA_ALLOW_REGISTRY_DRIFT=0

# ─── OPERATIONAL FLAGS (não-compliance, OK em qualquer ambiente) ─────────

# Fallback bind_tools for agents that don't support native tool calling
# Set to 1 to enable bind_tools fallback in _handle_directly path
LIA_FALLBACK_BIND_TOOLS=0  # R-044: verified-active — enables bind_tools in orchestrator._handle_directly() fallback path; 1=enable, 0=disable (default in .env; code defaults to true)

# YAML-based domain routing (loads DOMAIN_PATTERNS from domain_routing.yaml)
# Set to 1 to disable YAML loading and use hardcoded DOMAIN_PATTERNS
LIA_DISABLE_YAML_ROUTING=0  # R-044: verified-active — when 1, fast_router skips domain_routing.yaml and uses hardcoded DOMAIN_PATTERNS (emergency escape hatch)

# Disables SSE unified streaming envelope (operacional, fallback path)
LIA_DISABLE_SSE_UNIFIED=0

# Disables global response envelope middleware (operacional)
LIA_DISABLE_ENVELOPE_MIDDLEWARE=0

# Dev API key for local/testing access (bypasses JWT auth in dev mode)
LIA_DEV_API_KEY=

# ─── WIZARD JOB-CREATION TIMEOUTS (Task #1062 / D4 #1058) ─────────────────
# Timeouts em segundos por nó do graph `JobCreation`. Em timeout cada nó cai
# num fallback determinístico (sem LLM) — wizard nunca trava por Gemini lento
# ou 429. Override em test (ex.: 0.001) força o fallback para validação E2E.
LIA_JD_ENRICHMENT_TIMEOUT_S=12
LIA_BIGFIVE_TIMEOUT_S=10
LIA_WSI_QUESTIONS_TIMEOUT_S=20
LIA_SALARY_TIMEOUT_S=10

# Microsoft Teams Bot
# REQUIRED for TeamsProactivityEngine to initialize and send cards.
# Obtain from https://dev.botframework.com/ (App Registration in Azure AD).
# Without these, the bot silently skips all Teams notifications.
MICROSOFT_APP_ID=your_microsoft_app_id
MICROSOFT_APP_PASSWORD=your_microsoft_app_password
AZURE_TENANT_ID=your_azure_tenant_id
# Home tenant of the Bot App Registration (for outbound token acquisition)
# Same as AZURE_TENANT_ID in most setups. Required for Single Tenant bots.
TEAMS_APP_TENANT_ID=your_azure_tenant_id
TEAMS_WEBHOOK_URL=https://your-domain/api/v1/teams/webhook
# Optional: secret for Adaptive Card webhook signature validation (POST /teams/webhook)
TEAMS_WEBHOOK_SECRET=
# Public URL of this platform (used by Teams manifest and deep links)
WEDOTALENT_PLATFORM_URL=https://ai.wedotalent.cc

# Compliance report signing (NYC LL144 / EU AI Act tamper-evidence)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
REPORT_SIGNING_KEY=

# Atividade da IA no chat (epico 2026-06-03) — streaming de raciocinio
# ao vivo (reasoning_step) via astream em LangGraphBase._run_graph.
# Default OFF (usa ainvoke); fallback automatico para ainvoke em erro.
# Setar via Replit Secrets (este workspace popula os.environ por Secrets,
# nao carrega .env). Restart do servidor necessario para ter efeito.
LIA_WS_ASTREAM=false

# ─── CALENDAR INTEGRATION (GAP-06-001) ─────────────────────────────────────
# Integração com calendário externo para agendamento de entrevistas.
# Quando false (padrão): schedule_interview persiste no DB mas não sincroniza
# com agenda externa (calendar_synced=False no retorno).
# check_interviewer_availability e get_interview_status retornam erro honesto
# (calendar_not_configured) em vez de dados fabricados.
CALENDAR_INTEGRATION_ENABLED=false
# Google Calendar (requer OAuth2 app no Google Cloud Console)
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REDIRECT_URI=
# Microsoft Outlook / Teams (requer Azure AD App Registration — veja AZURE_TENANT_ID acima)
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=
