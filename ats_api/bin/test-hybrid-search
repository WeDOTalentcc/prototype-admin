#!/bin/bash
# Script para rodar testes unitários da busca híbrida

echo "======================================"
echo "Testes Unitários - Busca Híbrida"
echo "======================================"
echo ""

SPECS=(
  "spec/services/candidates/search/simple_query_detector_spec.rb"
  "spec/services/candidates/search/embedding_service_spec.rb"
  "spec/services/candidates/search/elasticsearch_strategy_spec.rb"
  "spec/services/candidates/search/embedding_strategy_spec.rb"
  "spec/services/candidates/search/hybrid_search_service_spec.rb"
  "spec/services/candidates/search/hybrid_search_service_v2_spec.rb"
)

PASSED=0
FAILED=0
TOTAL=0

for spec in "${SPECS[@]}"; do
  TOTAL=$((TOTAL + 1))
  echo "[$TOTAL/${#SPECS[@]}] Rodando: $(basename $spec)"
  
  if docker exec ats_api-web-1 bundle exec rspec "$spec" --format progress > /dev/null 2>&1; then
    echo "  ✅ PASSOU"
    PASSED=$((PASSED + 1))
  else
    echo "  ❌ FALHOU"
    FAILED=$((FAILED + 1))
  fi
  echo ""
done

echo "======================================"
echo "Resumo:"
echo "  Total: $TOTAL"
echo "  Passou: $PASSED"
echo "  Falhou: $FAILED"
echo "======================================"
