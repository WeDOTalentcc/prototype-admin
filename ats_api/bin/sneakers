#!/usr/bin/env ruby

# 1. Carrega o boot do Rails, que inicializa o Bundler.
require_relative '../config/boot'

# 2. Carrega o ambiente COMPLETO do Rails.
# Esta linha é a mais importante, pois executa o `Bundler.require`
# e carrega todos os inicializadores e classes da sua aplicação.
require_relative '../config/environment'

# 3. Agora que o ambiente está 100% carregado, as classes devem estar disponíveis.
STDOUT.sync = true

WORKERS = [
  MessageWorker::ProcessWorker
].freeze

Sneakers.configure(
  workers: WORKERS.size,
  threads: 2,
  log: Rails.logger,
  daemonize: false
)

runner = Sneakers::Runner.new(WORKERS)

def graceful_shutdown(runner)
  Rails.logger.info 'Desligando o worker do Sneakers...'
  runner.stop
  exit
end

Signal.trap('INT') { graceful_shutdown(runner) }
Signal.trap('TERM') { graceful_shutdown(runner) }

Rails.logger.info "Iniciando worker do Sneakers com auto-reloading ativado."

Rails.application.reloader.wrap do
  runner_thread = Thread.new { runner.run }
  loop { sleep 1 }
  runner_thread.join
end