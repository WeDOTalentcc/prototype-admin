<%# rubocop:disable all %>
<!DOCTYPE html>
<html>

<head>
  <title>WorkOS Authentication</title>
  <style>
    body {
      font-family: system-ui, -apple-system, sans-serif;
      padding: 40px;
      text-align: center;
      background: #f5f5f5;
    }

    .spinner {
      border: 4px solid #f3f3f3;
      border-top: 4px solid #3498db;
      border-radius: 50%;
      width: 40px;
      height: 40px;
      animation: spin 1s linear infinite;
      margin: 20px auto;
    }

    @keyframes spin {
      0% {
        transform: rotate(0deg);
      }

      100% {
        transform: rotate(360deg);
      }
    }
  </style>
</head>

<body>
  <div class="spinner"></div>
  <p>Authenticating...</p>
  <script>
    try {
      const message = <%= raw message.to_json %>;
      const envFrontUrl = '<%= ENV["FRONT_URL"] || "" %>';
      const frontUrl = envFrontUrl ||
        (window.opener && window.opener.location.origin) ||
        'http://localhost:3000';

      console.log('[WorkOS OAuth] Redirect flow - message:', message);
      console.log('[WorkOS OAuth] Frontend URL:', frontUrl);
      console.log('[WorkOS OAuth] ENV FRONT_URL:', envFrontUrl);

      if (!message) {
        console.error('[WorkOS OAuth] No message received');
        throw new Error('No message data');
      }

      if (message.success && message.session) {
        // Success: redirect to frontend with token in query params
        const params = new URLSearchParams({
          token: message.session.token,
          user: JSON.stringify(message.session.user)
        });
        if (message.session.graph_auth_url) {
          params.append('graph_auth_url', message.session.graph_auth_url);
        }
        const redirectUrl = frontUrl + '/auth/callback?' + params.toString();
        console.log('[WorkOS OAuth] ✅ Redirecting to:', redirectUrl);
        window.location.href = redirectUrl;
      } else {
        // Error: redirect to login with error message
        const params = new URLSearchParams({
          error: (message && message.error) || 'Login failed'
        });
        const redirectUrl = frontUrl + '/login?' + params.toString();
        console.error('[WorkOS OAuth] ❌ Error, redirecting to:', redirectUrl);
        window.location.href = redirectUrl;
      }
    } catch (error) {
      console.error('[WorkOS OAuth] Fatal error:', error);
      document.querySelector('p').textContent = 'Error: ' + error.message;
    }
  </script>
</body>

</html>