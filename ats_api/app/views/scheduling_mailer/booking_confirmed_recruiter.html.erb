<% content_for :title, "Entrevista Agendada - WeDO Talent" %>

<%= render layout: 'shared/mailer/email_layout' do %>

  <%= render 'shared/mailer/email_header' %>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 32px 32px 0;">
        <p style="margin: 0 0 4px 0; font-size: 11px; font-weight: 700; color: #60BED1; text-transform: uppercase; letter-spacing: 0.1em;">
          Novo agendamento
        </p>
        <h1 style="margin: 0 0 24px 0; font-size: 22px; font-weight: 700; color: #111827; line-height: 1.3;">
          Um candidato agendou uma entrevista
        </h1>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <p style="margin: 0; font-size: 15px; line-height: 1.7; color: #374151;">
          Um candidato agendou uma entrevista através do seu link de agendamento.
        </p>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f9fafb; border: 1px solid #f3f4f6; border-radius: 10px;">
          <%= render 'shared/mailer/email_info_row', label: 'Assunto', value: @meeting.subject, border: true %>
          <%= render 'shared/mailer/email_info_row', label: 'Data', value: @meeting.start_time.strftime('%d/%m/%Y'), border: true %>
          <%= render 'shared/mailer/email_info_row', label: 'Horário', value: "#{@meeting.start_time.strftime('%H:%M')} - #{@meeting.end_time.strftime('%H:%M')}", border: true %>
          <% if @candidate %>
            <%= render 'shared/mailer/email_info_row', label: 'Candidato', value: @candidate.name, border: @meeting.location.present? %>
          <% end %>
          <% if @meeting.location.present? %>
            <%= render 'shared/mailer/email_info_row', label: 'Local', value: @meeting.location, border: false %>
          <% end %>
        </table>
      </td>
    </tr>
  </table>

<% end %>
