<% content_for :title, "Agende sua Entrevista - WeDO Talent" %>

<%= render layout: 'shared/mailer/email_layout' do %>

  <%= render 'shared/mailer/email_header' %>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 32px 32px 0;">
        <p style="margin: 0 0 4px 0; font-size: 11px; font-weight: 700; color: #60BED1; text-transform: uppercase; letter-spacing: 0.1em;">
          Agendamento de entrevista
        </p>
        <h1 style="margin: 0 0 24px 0; font-size: 22px; font-weight: 700; color: #111827; line-height: 1.3;">
          <%= @link.subject.presence || "Agende sua Entrevista" %>
        </h1>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <p style="margin: 0 0 16px 0; font-size: 15px; line-height: 1.7; color: #374151;">
          Olá, <strong style="color: #111827;"><%= @candidate.name %></strong>.
        </p>
        <% if @link.message.present? %>
          <p style="margin: 0; font-size: 15px; line-height: 1.7; color: #374151;">
            <%= @link.message %>
          </p>
        <% else %>
          <p style="margin: 0; font-size: 15px; line-height: 1.7; color: #374151;">
            Você foi convidado(a) para agendar uma entrevista. Escolha o melhor horário para você.
          </p>
        <% end %>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f9fafb; border: 1px solid #f3f4f6; border-radius: 10px;">
          <% if @link.interview_type.present? %>
            <%= render 'shared/mailer/email_info_row', label: 'Tipo', value: @link.interview_type.humanize, border: true %>
          <% end %>
          <%= render 'shared/mailer/email_info_row', label: 'Duração', value: "#{@link.duration_minutes} minutos", border: true %>
          <% if @link.platform.present? %>
            <%= render 'shared/mailer/email_info_row', label: 'Plataforma', value: @link.platform.humanize, border: true %>
          <% end %>
          <% if @link.location.present? %>
            <%= render 'shared/mailer/email_info_row', label: 'Local', value: @link.location, border: true %>
          <% end %>
          <% if @link.expires_at %>
            <%= render 'shared/mailer/email_info_row', label: 'Válido até', value: @link.expires_at.strftime("%d/%m/%Y às %H:%M"), border: false %>
          <% end %>
        </table>
      </td>
    </tr>
  </table>

  <%= render 'shared/mailer/email_button', url: @scheduling_url, text: 'Escolher Horário' %>

<% end %>
