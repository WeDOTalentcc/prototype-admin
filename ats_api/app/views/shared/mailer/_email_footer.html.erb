<% api_url = ENV["API_URL"] || "http://localhost:8080" %>
<% site_url = "https://wedotalent.com" %>
<table role="presentation" cellpadding="0" cellspacing="0" width="100%">
  <tr>
    <td style="background-color: #0d0d0d; border-top: 1px solid #1f1f1f;">

      <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
        <tr>
          <td style="padding: 28px 32px 0;">
            <img src="<%= api_url %>/wedonew.jpeg" alt="WeDO Talent" height="36" style="display: block; border-radius: 4px; margin-bottom: 12px;">
            <p style="margin: 0 0 4px 0; font-size: 12px; color: #9ca3af; line-height: 1.5;">Tecnologia avançada para o RH do futuro.</p>
            <p style="margin: 0; font-size: 11px; color: #6b7280; line-height: 1.5;">Powered by <span style="font-weight: 700;">LIA</span>, agente de inteligência artificial de recrutamento.</p>
          </td>
        </tr>
      </table>

      <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
        <tr>
          <td style="padding: 20px 32px 0;">
            <table role="presentation" cellpadding="0" cellspacing="0">
              <tr>
                <td style="padding-right: 8px;">
                  <a href="https://www.linkedin.com/company/wedotalent" target="_blank" style="display: inline-block; width: 32px; height: 32px; background-color: #1f1f1f; border-radius: 8px; text-align: center; text-decoration: none;">
                    <img src="data:image/svg+xml;base64," alt="LinkedIn" width="16" height="16" style="display: block; margin: 8px auto;">
                  </a>
                </td>
                <td>
                  <a href="mailto:contato@wedotalent.cc" style="display: inline-block; width: 32px; height: 32px; background-color: #1f1f1f; border-radius: 8px; text-align: center; text-decoration: none;">
                    <img src="data:image/svg+xml;base64," alt="Email" width="16" height="16" style="display: block; margin: 8px auto;">
                  </a>
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>

      <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
        <tr>
          <td style="padding: 20px 32px 24px; border-top: 1px solid #1f1f1f; margin-top: 20px;">
            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
              <tr>
                <td style="font-size: 11px; color: #6b7280; line-height: 1.5;">
                  © <%= Time.current.year %> WeDOTalent. Todos os direitos reservados.
                </td>
                <td align="right" style="font-size: 11px; line-height: 1.5;">
                  <a href="<%= site_url %>/privacidade" style="color: #6b7280; text-decoration: none;">Privacidade</a>
                  <span style="color: #374151; padding: 0 4px;">·</span>
                  <a href="<%= site_url %>/termos" style="color: #6b7280; text-decoration: none;">Termos</a>
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>

    </td>
  </tr>
</table>
