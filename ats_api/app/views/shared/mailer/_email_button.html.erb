<table role="presentation" cellpadding="0" cellspacing="0" width="100%">
  <tr>
    <td align="center" style="padding: 0 32px 28px;">
      <table role="presentation" cellpadding="0" cellspacing="0">
        <tr>
          <td align="center" style="background-color: #111827; border-radius: 10px;">
            <a href="<%= url %>" target="_blank" style="display: inline-block; padding: 14px 36px; font-size: 13px; font-weight: 700; color: #ffffff; text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase;">
              <%= text %>
            </a>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
