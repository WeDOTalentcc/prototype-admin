<table role="presentation" cellpadding="0" cellspacing="0" width="100%">
  <tr>
    <td align="center" style="padding: 0 32px 8px;">
      <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
        <tr>
          <td align="center" style="padding-right: 6px;" width="50%">
            <a href="<%= primary_url %>" target="_blank" style="display: block; padding: 14px 24px; font-size: 13px; font-weight: 700; color: #ffffff; background-color: #111827; text-decoration: none; border-radius: 10px; text-align: center; letter-spacing: 0.04em; text-transform: uppercase;">
              <%= primary_text %>
            </a>
          </td>
          <td align="center" style="padding-left: 6px;" width="50%">
            <a href="<%= secondary_url %>" style="display: block; padding: 14px 24px; font-size: 13px; font-weight: 700; color: #374151; background-color: #ffffff; text-decoration: none; border-radius: 10px; text-align: center; letter-spacing: 0.04em; text-transform: uppercase; border: 1px solid #e5e7eb;">
              <%= secondary_text %>
            </a>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
