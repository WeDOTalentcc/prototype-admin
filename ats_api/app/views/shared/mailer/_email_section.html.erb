<table role="presentation" cellpadding="0" cellspacing="0" width="100%">
  <tr>
    <td style="padding: 0 32px;">
      <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="border-top: 1px solid #f3f4f6;">
        <tr>
          <td style="padding: 24px 0 8px;">
            <p style="margin: 0; font-size: 11px; font-weight: 700; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.1em;">
              <%= title %>
            </p>
          </td>
        </tr>
        <tr>
          <td style="padding-bottom: <%= local_assigns.fetch(:padding_bottom, '20px') %>;">
            <p style="margin: 0; font-size: 14px; line-height: 1.7; color: #374151;">
              <%= body %>
            </p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
