<% content_for :title, "Problema no Screening - WeDO Talent" %>

<%= render layout: 'shared/mailer/email_layout' do %>

  <%= render 'shared/mailer/email_header' %>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 32px 32px 0;">
        <p style="margin: 0 0 4px 0; font-size: 11px; font-weight: 700; color: #dc2626; text-transform: uppercase; letter-spacing: 0.1em;">
          Problema reportado
        </p>
        <h1 style="margin: 0 0 24px 0; font-size: 22px; font-weight: 700; color: #111827; line-height: 1.3;">
          Problema reportado no Screening
        </h1>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f9fafb; border: 1px solid #f3f4f6; border-radius: 10px;">
          <%= render 'shared/mailer/email_info_row', label: 'Conteúdo', value: simple_format(@content), border: true %>
          <%= render 'shared/mailer/email_info_row', label: 'Nome', value: @candidate_name, border: true %>
          <%= render 'shared/mailer/email_info_row', label: 'Telefone', value: @mobile_phone, border: true %>
          <%= render 'shared/mailer/email_info_row', label: 'E-mail', value: @email, border: true %>
          <%= render 'shared/mailer/email_info_row', label: 'Data', value: @issue_date.strftime("%d/%m/%Y às %H:%M"), border: true %>
          <%= render 'shared/mailer/email_info_row', label: 'Vaga', value: @job_name, border: false %>
        </table>
      </td>
    </tr>
  </table>

<% end %>
