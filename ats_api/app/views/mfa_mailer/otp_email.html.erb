<% content_for :title, "Código de Verificação - WeDO Talent" %>

<%= render layout: 'shared/mailer/email_layout' do %>

  <%= render 'shared/mailer/email_header' %>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 32px 32px 0;">
        <p style="margin: 0 0 4px 0; font-size: 11px; font-weight: 700; color: #60BED1; text-transform: uppercase; letter-spacing: 0.1em;">
          Verificação de Segurança
        </p>
        <h1 style="margin: 0 0 24px 0; font-size: 22px; font-weight: 700; color: #111827; line-height: 1.3;">
          Seu código de acesso
        </h1>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <p style="margin: 0; font-size: 15px; line-height: 1.7; color: #374151;">
          Olá, <strong style="color: #111827;"><%= @user.name || @user.email.split('@').first.capitalize %></strong>!
          Use o código abaixo para completar seu login:
        </p>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f9fafb; border: 1px solid #f3f4f6; border-radius: 10px; text-align: center;">
          <tr>
            <td style="padding: 32px 20px;">
              <p style="margin: 0 0 8px 0; font-size: 12px; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 0.1em;">
                Código de Verificação
              </p>
              <p style="margin: 16px 0; font-size: 48px; font-weight: 700; color: #111827; letter-spacing: 8px; font-family: 'Inter', 'Courier New', Courier, monospace;">
                <%= @code %>
              </p>
              <p style="margin: 0; font-size: 13px; color: #60BED1;">
                ⏱ Válido por <%= @expires_in %>
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f9fafb; border: 1px solid #f3f4f6; border-radius: 10px;">
          <tr>
            <td style="padding: 16px 20px; border-bottom: 1px solid #f3f4f6;">
              <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td width="24" style="font-size: 14px; color: #22C55E; vertical-align: top; padding-right: 12px;">✓</td>
                  <td style="font-size: 13px; color: #374151; line-height: 1.5;">Código expira em <strong><%= @expires_in %></strong></td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="padding: 16px 20px; border-bottom: 1px solid #f3f4f6;">
              <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td width="24" style="font-size: 14px; color: #22C55E; vertical-align: top; padding-right: 12px;">✓</td>
                  <td style="font-size: 13px; color: #374151; line-height: 1.5;">Pode ser usado apenas uma vez</td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="padding: 16px 20px;">
              <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td width="24" style="font-size: 14px; color: #22C55E; vertical-align: top; padding-right: 12px;">✓</td>
                  <td style="font-size: 13px; color: #374151; line-height: 1.5;">Não compartilhe com ninguém</td>
                </tr>
              </table>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 28px;">
        <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #fffbeb; border: 1px solid #fef3c7; border-radius: 10px;">
          <tr>
            <td style="padding: 16px 20px;">
              <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                <tr>
                  <td width="24" style="font-size: 16px; color: #f59e0b; vertical-align: top; padding-right: 12px;">⚠️</td>
                  <td style="font-size: 13px; color: #92400e; line-height: 1.5;">
                    <strong>Não solicitou este código?</strong> Ignore este email. Sua conta permanece segura.
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

<% end %>
