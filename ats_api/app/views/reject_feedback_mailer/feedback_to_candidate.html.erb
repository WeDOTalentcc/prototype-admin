<% content_for :title, "Atualização sobre sua candidatura - WeDO Talent" %>

<%= render layout: 'shared/mailer/email_layout' do %>

  <%= render 'shared/mailer/email_header' %>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 32px 32px 0;">
        <p style="margin: 0 0 4px 0; font-size: 11px; font-weight: 700; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.1em;">
          Processo seletivo
        </p>
        <h1 style="margin: 0 0 24px 0; font-size: 22px; font-weight: 700; color: #111827; line-height: 1.3;">
          Olá, <%= @candidate.name %>.
        </h1>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <p style="margin: 0 0 16px 0; font-size: 15px; line-height: 1.7; color: #374151;">
          Segue o retorno sobre sua candidatura à vaga de <strong style="color: #111827;"><%= @job.title %></strong>:
        </p>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f9fafb; border-left: 4px solid #60BED1; border-radius: 0 10px 10px 0;">
          <tr>
            <td style="padding: 20px 24px;">
              <div style="font-size: 14px; line-height: 1.7; color: #374151;">
                <%= simple_format(@feedback_description) %>
              </div>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <p style="margin: 0; font-size: 14px; line-height: 1.7; color: #374151;">
          Agradecemos seu interesse e o tempo dedicado ao processo. Desejamos sucesso em sua trajetória profissional e ficamos à disposição para futuras oportunidades.
        </p>
      </td>
    </tr>
  </table>

  <%= render 'shared/mailer/email_signature',
    name: 'Equipe WeDO Talent', role: 'Recrutamento', company: 'WeDO Talent' %>

<% end %>
