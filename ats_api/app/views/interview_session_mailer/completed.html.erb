<% content_for :title, "Entrevista Concluída - WeDO Talent" %>

<%= render layout: 'shared/mailer/email_layout' do %>

  <%= render 'shared/mailer/email_header' %>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 32px 32px 0;">
        <p style="margin: 0 0 4px 0; font-size: 11px; font-weight: 700; color: #22C55E; text-transform: uppercase; letter-spacing: 0.1em;">
          Entrevista concluída
        </p>
        <h1 style="margin: 0 0 24px 0; font-size: 22px; font-weight: 700; color: #111827; line-height: 1.3;">
          <%= @candidate_name %> finalizou a triagem por voz
        </h1>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <p style="margin: 0; font-size: 15px; line-height: 1.7; color: #374151;">
          A triagem por voz com <strong style="color: #111827;"><%= @candidate_name %></strong> para a vaga de
          <strong style="color: #111827;"><%= @job_title %></strong> foi concluída.
        </p>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f9fafb; border: 1px solid #f3f4f6; border-radius: 10px;">
          <%= render 'shared/mailer/email_info_row', label: 'Candidato', value: @candidate_name, border: true %>
          <%= render 'shared/mailer/email_info_row', label: 'Vaga', value: @job_title, border: true %>
          <%= render 'shared/mailer/email_info_row', label: 'Nota', value: "#{@score&.round(1)} / 10", border: true %>
          <%= render 'shared/mailer/email_info_row', label: 'Recomendação', value: @recommendation, border: false %>
        </table>
      </td>
    </tr>
  </table>

<% end %>
