<% content_for :title, "Avaliação Recusada - WeDO Talent" %>

<%= render layout: 'shared/mailer/email_layout' do %>

  <%= render 'shared/mailer/email_header' %>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 32px 32px 0;">
        <p style="margin: 0 0 4px 0; font-size: 11px; font-weight: 700; color: #EF4444; text-transform: uppercase; letter-spacing: 0.1em;">
          Avaliação recusada
        </p>
        <h1 style="margin: 0 0 24px 0; font-size: 22px; font-weight: 700; color: #111827; line-height: 1.3;">
          <%= @candidate_name %> recusou a avaliação
        </h1>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <p style="margin: 0; font-size: 15px; line-height: 1.7; color: #374151;">
          O candidato <strong style="color: #111827;"><%= @candidate_name %></strong> recusou participar da avaliação
          <strong style="color: #111827;"><%= @evaluation_name %></strong>.
        </p>
      </td>
    </tr>
  </table>

  <% if @declined_reason.present? %>
  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <p style="margin: 0 0 8px 0; font-size: 13px; font-weight: 600; color: #6B7280; text-transform: uppercase; letter-spacing: 0.05em;">
          Motivo da recusa
        </p>
        <p style="margin: 0; padding: 16px; background-color: #FEF3F2; border-left: 4px solid #EF4444; border-radius: 6px; font-size: 14px; line-height: 1.6; color: #374151;">
          <%= @declined_reason %>
        </p>
      </td>
    </tr>
  </table>
  <% end %>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f9fafb; border: 1px solid #f3f4f6; border-radius: 10px;">
          <%= render 'shared/mailer/email_info_row', label: 'Candidato', value: @candidate_name, border: true %>
          <%= render 'shared/mailer/email_info_row', label: 'Email', value: @candidate_email, border: true %>
          <%= render 'shared/mailer/email_info_row', label: 'Avaliação', value: @evaluation_name, border: true %>
          <%= render 'shared/mailer/email_info_row', label: 'Vaga', value: @job_title, border: true %>
          <%= render 'shared/mailer/email_info_row', label: 'Recusado em', value: @declined_at, border: false %>
        </table>
      </td>
    </tr>
  </table>

  <%= render 'shared/mailer/email_button', url: @candidate_url, text: 'Ver Candidato' %>

<% end %>
