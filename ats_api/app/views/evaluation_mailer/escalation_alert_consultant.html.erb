<% content_for :title, "Alerta: Triagem não concluída - WeDO Talent" %>

<%= render layout: 'shared/mailer/email_layout' do %>

  <%= render 'shared/mailer/email_header' %>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 32px 32px 0;">
        <p style="margin: 0 0 4px 0; font-size: 11px; font-weight: 700; color: #dc2626; text-transform: uppercase; letter-spacing: 0.1em;">
          Alerta — Triagem não concluída
        </p>
        <h1 style="margin: 0 0 24px 0; font-size: 22px; font-weight: 700; color: #111827; line-height: 1.3;">
          Candidato não concluiu a triagem
        </h1>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <p style="margin: 0 0 16px 0; font-size: 15px; line-height: 1.7; color: #374151;">
          O candidato <strong style="color: #111827;"><%= @candidate_name %></strong> não concluiu a avaliação
          <strong style="color: #111827;"><%= @evaluation_name %></strong> após 96 horas.
        </p>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f9fafb; border: 1px solid #f3f4f6; border-radius: 10px;">
          <%= render 'shared/mailer/email_info_row', label: 'Candidato', value: @candidate_name, border: true %>
          <%= render 'shared/mailer/email_info_row', label: 'Avaliação', value: @evaluation_name, border: true %>
          <%= render 'shared/mailer/email_info_row', label: 'Vaga', value: @job_title, border: true %>
          <%= render 'shared/mailer/email_info_row', label: 'Convite enviado em', value: @created_at, border: false %>
        </table>
      </td>
    </tr>
  </table>

  <%= render 'shared/mailer/email_button', url: @candidate_url, text: 'Ver Candidato' %>

<% end %>
