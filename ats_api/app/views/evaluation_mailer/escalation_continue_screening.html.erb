<% content_for :title, "Continue sua triagem - WeDO Talent" %>
<% content_for :disclaimer, "Ao iniciar, você concorda com o tratamento de seus dados conforme nossa Política de Privacidade." %>

<%= render layout: 'shared/mailer/email_layout' do %>

  <%= render 'shared/mailer/email_header', company_name: @company_name %>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 32px 32px 0;">
        <p style="margin: 0 0 4px 0; font-size: 11px; font-weight: 700; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.1em;">
          Lembrete — <%= @company_name %>
        </p>
        <h1 style="margin: 0 0 24px 0; font-size: 24px; font-weight: 700; color: #111827; line-height: 1.3;">
          Olá, <%= @candidate_name %>.
        </h1>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <p style="margin: 0 0 16px 0; font-size: 15px; line-height: 1.7; color: #374151;">
          Você ainda não concluiu a conversa com a <strong style="color: #111827;">LIA</strong> sobre a vaga de
          <strong style="color: #111827;"><%= @job_title %></strong>.
        </p>
        <p style="margin: 0; font-size: 15px; line-height: 1.7; color: #374151;">
          Reserve alguns minutos para continuar. O processo é assíncrono — você pode pausar e retomar quando quiser.
        </p>
      </td>
    </tr>
  </table>

  <%= render 'shared/mailer/email_dual_buttons',
    primary_url: @evaluation_url, primary_text: 'Continuar Triagem',
    secondary_url: "#{@evaluation_url}?action=decline", secondary_text: 'Não Tenho Interesse' %>

  <%= render 'shared/mailer/email_signature',
    name: @recruiter_name, role: @recruiter_role, company: @company_name %>

<% end %>
