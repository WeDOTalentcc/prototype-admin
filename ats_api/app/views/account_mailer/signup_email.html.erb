<% content_for :title, "Bem-vindo - WeDO Talent" %>

<%= render layout: 'shared/mailer/email_layout' do %>

  <%= render 'shared/mailer/email_header', company_name: @account_name %>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 32px 32px 0;">
        <p style="margin: 0 0 4px 0; font-size: 11px; font-weight: 700; color: #60BED1; text-transform: uppercase; letter-spacing: 0.1em;">
          Novo acesso
        </p>
        <h1 style="margin: 0 0 24px 0; font-size: 22px; font-weight: 700; color: #111827; line-height: 1.3;">
          Bem-vindo ao <%= @account_name %>!
        </h1>
      </td>
    </tr>
  </table>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 24px;">
        <div style="margin: 0; font-size: 14px; line-height: 1.7; color: #374151;">
          <%= simple_format(@content) %>
        </div>
      </td>
    </tr>
  </table>

  <%= render 'shared/mailer/email_button', url: @setup_url, text: 'Complete seu Cadastro' %>

  <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
    <tr>
      <td style="padding: 0 32px 28px;">
        <p style="margin: 0; font-size: 12px; color: #9ca3af; line-height: 1.5;">
          Ou copie e cole este link no seu navegador:<br>
          <a href="<%= @setup_url %>" style="color: #60BED1; text-decoration: underline; word-break: break-all;"><%= @setup_url %></a>
        </p>
      </td>
    </tr>
  </table>

<% end %>
