   743	            ``None`` se supervisor desabilitado / fail-OPEN — caller cai
   744	            no fluxo legacy (continue_current).
   745	
   746	            ``{"intent": str, "short_circuit": False}`` se intent é
   747	            ``continue_current`` / ``create_new`` / ``resume_draft`` /
   748	            ``edit_published`` — caller segue para o graph (esses 3
   749	            últimos terão handlers próprios nas Tasks #1128+).
   750	
   751	            ``{"intent": "meta_question", "short_circuit": True,
   752	            "message": str, "ws_stage_payload": dict}`` quando o
   753	            supervisor classifica como meta — caller responde direto sem
   754	            tocar o graph.
   755	
   756	            ``{"intent": "exit_wizard", "short_circuit": True,
   757	            "message": str, "ws_stage_payload": dict}`` quando o
   758	            supervisor classifica como saída — caller emite despedida.
   759	        """
   760	        from app.domains.job_creation.services.wizard_supervisor_classifier import (
   761	            get_wizard_supervisor_classifier,
   762	            is_supervisor_enabled,
   763	        )
   764	
   765	        if not is_supervisor_enabled():
   766	            return None
   767	
   768	        # Contexto mínimo para o classifier — sem PII, snippets curtos.
   769	        ctx = context or {}
   770	        prior = prior_state or {}
   771	        current_stage = prior.get("current_stage") if isinstance(prior, dict) else None
   772	
   773	        # tenant snippet via helper canônico (NON-ReAct callsite — T-F).
   774	        # Assinatura canônica: (ctx, *, agent_name, company_id_raw).
   775	        # NÃO use kwargs `company_id=`/`context=` — TypeError silenciado
   776	        # quebraria a postura de governança T-F.
   777	        tenant_snippet = ""
   778	        try:
   779	            from app.shared.agents.tenant_aware_agent import (
   780	                resolve_tenant_snippet_for_non_react,
   781	            )
   782	            tenant_snippet = (
   783	                resolve_tenant_snippet_for_non_react(
