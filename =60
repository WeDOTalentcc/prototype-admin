   153	def _compute_supervisor_skip(
   154	    user_message: str | None, prior_stage: str | None,
   155	) -> bool:
   156	    """Decide if pre-graph supervisor classifier should be skipped.
   157	
   158	    Contract:
   159	      skip ⇔ (prior_stage in _ACTIVE_WIZARD_STAGES)
   160	             AND (len(user_message.strip()) < _SUPERVISOR_SKIP_LONG_CONTENT_THRESHOLD)
   161	
   162	    Skip protects short HITL prompt-answers from being re-classified
   163	    (Sprint F.2). Long content (JD pastes, briefings) MUST re-classify
   164	    so the graph can ingest new substance instead of swallowing it as
   165	    a no-op HITL answer (Sprint F.2-v2).
   166	    """
   167	    if not isinstance(prior_stage, str) or prior_stage not in _ACTIVE_WIZARD_STAGES:
   168	        return False
   169	    msg_len = len((user_message or "").strip())
   170	    return msg_len < _SUPERVISOR_SKIP_LONG_CONTENT_THRESHOLD
