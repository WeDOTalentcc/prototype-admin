   306	def _emit_silent_fallback(
   307	    *,
   308	    stage: str | None,
   309	    company_id: Any,
   310	    session_id: str | None,
   311	    thread_id: str | None,
   312	    conversation_tail: list[dict] | None,
   313	    cause: str,
   314	) -> None:
   315	    """Task #1089 (T3) — fail-LOUD path quando o graph não devolve mensagem.
   316	    Combina:
   317	      (a) ``logger.error`` com contexto completo;
   318	      (b) Sentry ``capture_message`` (level=error) em prod;
   319	      (c) audit row ``decision_type=wizard_fallback_invoked`` (EU AI Act);
   320	      (d) Prometheus counter via :func:`WizardFallbackTracker.record_fallback`
   321	          (label ``stage``, escopo session+tenant, threshold de alerta).
   322	    Todas as 4 sub-chamadas são fail-open individualmente — telemetria nunca
   323	    derruba o turno do recrutador."""
   324	    cid = str(company_id) if company_id else None
   325	    stage_label = stage or "unknown"
   326	
   327	    # Sanitized bounded tail snapshot p/ diagnosticabilidade (R-013 / code
   328	    # review #2): mantém apenas role + 200 chars do content dos últimos 3
   329	    # turnos. PII leakage mitigado pelo truncate; log nunca explode.
   330	    tail_snapshot: list[dict] = []
   331	    for _msg in (conversation_tail or [])[-3:]:
   332	        if not isinstance(_msg, dict):
   333	            continue
   334	        _role = str(_msg.get("role") or "")[:24]
   335	        _content = str(_msg.get("content") or "").strip()[:200]
   336	        if _content:
   337	            tail_snapshot.append({"role": _role, "content_excerpt": _content})
   338	
   339	    logger.error(
   340	        "[WizardSession] silent fallback invoked stage=%s session=%s thread=%s "
   341	        "company=%s cause=%s tail_len=%s tail=%s — graph returned no message",
   342	        stage_label, session_id, thread_id, cid, cause,
   343	        len(conversation_tail or []), tail_snapshot,
   344	    )
   345	
   346	    # (b) Sentry
   347	    try:  # pragma: no cover — Sentry opcional em testes
   348	        import sentry_sdk
   349	        sentry_sdk.capture_message(
   350	            f"Wizard silent fallback invoked (stage={stage_label})",
   351	            level="error",
   352	            extras={
   353	                "stage": stage_label,
   354	                "session_id": session_id,
   355	                "thread_id": thread_id,
   356	                "company_id": cid,
   357	                "cause": cause,
   358	            },
   359	        )
   360	    except Exception:
   361	        pass
   362	
   363	    # (c) Audit row
   364	    try:
   365	        from app.shared.compliance.audit_service import AuditService
   366	
   367	        if cid:
   368	            asyncio.create_task(AuditService().log_decision(  # AUDIT-NO-DEMO: wizard fallback telemetry (job creation flow, no candidate decision; LGPD Art.20 N/A)
   369	                company_id=cid,
   370	                agent_name=f"wizard_session:{stage_label}",
   371	                decision_type="wizard_fallback_invoked",
   372	                action=f"silent_fallback_{stage_label}",
   373	                decision="fallback_emitted",
   374	                reasoning=[
   375	                    f"stage={stage_label}",
   376	                    f"cause={cause}",
   377	                    f"session_id={session_id or '∅'}",
   378	                    f"thread_id={thread_id or '∅'}",
   379	                ],
   380	                criteria_used=[
   381	                    "wizard_fallback",
   382	                    f"stage:{stage_label}",
   383	                    f"cause:{cause}",
   384	                ],
   385	                human_review_required=True,
   386	            ))
   387	    except Exception as audit_exc:  # noqa: BLE001
   388	        logger.warning(
   389	            "[WizardSession] fallback audit emission failed (fail-open): %s",
   390	            audit_exc,
   391	        )
   392	
   393	    # (d) Prometheus counter explícito (Task #1089 / code review #2 follow-up)
   394	    if _SILENT_FALLBACK_COUNTER is not None:
   395	        try:
   396	            _SILENT_FALLBACK_COUNTER.labels(
   397	                stage=stage_label, company_id=(cid or "∅"), cause=cause,
   398	            ).inc()
   399	        except Exception as pm_exc:  # noqa: BLE001
   400	            logger.warning(
   401	                "[WizardSession] prometheus counter inc failed (fail-open): %s",
   402	                pm_exc,
   403	            )
   404	
   405	    # (e) Fallback tracker (rolling-window threshold + alerta agregado)
   406	    try:
   407	        from app.shared.observability.wizard_fallback_tracker import (
   408	            get_wizard_fallback_tracker,
   409	        )
   410	        get_wizard_fallback_tracker().record_fallback(
   411	            session_id=session_id, company_id=cid,
   412	            stage=stage_label, reason=f"silent_{cause}",
   413	        )
   414	    except Exception as tr_exc:  # noqa: BLE001
   415	        logger.warning(
   416	            "[WizardSession] fallback tracker emission failed (fail-open): %s",
   417	            tr_exc,
   418	        )
