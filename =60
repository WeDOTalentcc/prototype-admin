    68	def _derive_wizard_stage(state: dict) -> str:
    69	    """Deriva o stage canonical a partir do progresso do estado.
    70	
    71	    O orquestrador é não-linear (não tem máquina de stages rígida), mas o
    72	    painel lateral é stage-driven. Derivamos o stage do conteúdo do estado
    73	    para o painel transicionar naturalmente (ficha → JD → publicado).
    74	    """
    75	    # Bug 13: calibração pós-publish — candidatos em calibração + vaga publicada
    76	    # + calibração NÃO concluída → manter no stage de calibração.
    77	    # guard not calibration_complete para cair em handoff após advance_calibration.
    78	    # Bug B fix: isinstance(list) em vez de truthiness — [] (0 candidatos Rails)
    79	    # também sinaliza "fase de calibração iniciada". None/ausente = não iniciada.
    80	    _calib_cands = state.get("calibration_candidates")
    81	    if (
    82	        isinstance(_calib_cands, list)
    83	        and state.get("job_id")
    84	        and not state.get("calibration_complete")
    85	    ):
    86	        return "calibration"
    87	    # Navegação explícita OU pós-publish → handoff (o FE auto-navega para a
    88	    # página de vagas quando currentStage == "handoff").
    89	    if state.get("_navigate_to_jobs") or state.get("job_id"):
    90	        return "handoff"
    91	    if state.get("wsi_questions"):
    92	        return "wsi_questions"
    93	    if state.get("jd_enriched"):
    94	        return "jd_enrichment"
    95	    # B3 fix (2026-05-31): stage "competency" — quando há competências
    96	    # sugeridas/confirmadas (mas JD ainda não gerada), o painel mostra o
    97	    # CompetencyPanel (add/remove). Antes o orquestrador pulava direto de
    98	    # intake p/ jd_enrichment e o painel de competências nunca aparecia.
    99	    if (
   100	        state.get("confirmed_technical_competencies")
   101	        or state.get("confirmed_behavioral_competencies")
   102	        or state.get("suggested_competencies")
   103	    ):
   104	        return "competency"
   105	    return "intake"
