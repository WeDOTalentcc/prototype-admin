   223	async def _generate_fallback_reply(
   224	    *,
   225	    stage: str | None,
   226	    conversation_tail: list[dict] | None,
   227	    tenant_snippet: str | None,
   228	) -> str:
   229	    """LLM-based contextual fallback. Cheap model (Haiku), 3s timeout, safe
   230	    fallback to hard-prefixed message on any failure. Disabled in tests via
   231	    LIA_WIZARD_FALLBACK_LLM_DISABLED=1."""
   232	    if os.environ.get("LIA_WIZARD_FALLBACK_LLM_DISABLED", "").strip() in {"1", "true", "yes"}:
   233	        return _build_hard_fallback_message(stage)
   234	    try:
   235	        from langchain_core.messages import HumanMessage, SystemMessage  # type: ignore
   236	
   237	        from app.shared.llm_models import CANONICAL_HAIKU_MODEL
   238	        from app.shared.providers.anthropic_client import get_chat_anthropic
   239	
   240	        model_name = os.environ.get(
   241	            "LIA_WIZARD_FALLBACK_MODEL", CANONICAL_HAIKU_MODEL,
   242	        )
   243	        timeout_s = float(os.environ.get("LIA_WIZARD_FALLBACK_TIMEOUT_S", "3"))
   244	        # Task #1166: centralized seam — proxy ``base_url`` is enforced
   245	        # by the bootstrap monkey-patch and the AST sentinel forbids
   246	        # bare ``ChatAnthropic(...)`` inside ``app/domains/job_creation/``.
   247	        llm = get_chat_anthropic(
   248	            model=model_name, temperature=0, timeout=timeout_s, max_tokens=200,
   249	        )
   250	
   251	        tail_lines: list[str] = []
   252	        for msg in (conversation_tail or [])[-4:]:
   253	            role = (msg.get("role") or "").lower()
   254	            content = str(msg.get("content") or "").strip()[:300]
   255	            if content:
   256	                tail_lines.append(f"- {role or 'msg'}: {content}")
   257	        tail_text = "\n".join(tail_lines) or "(sem histórico)"
   258	        sys = (
   259	            "Você é a LIA, assistente de recrutamento. O wizard está em estado "
   260	            f"inconsistente na etapa '{stage or 'wizard'}'. Gere UMA resposta curta "
   261	            "(1-2 frases) em PT-BR, natural, perguntando o que o recrutador quer "
   262	            "fazer (tentar de novo, revisar o registrado, ou pedir ajuda). NÃO "
   263	            "invente conteúdo da vaga. NÃO repita prompts canned como 'preciso da "
   264	            "sua aprovação'. NUNCA peça ao recrutador dados do tenant "
   265	            "(company_id, id da empresa, nome da empresa, setor, plano, "
   266	            "nome do consultor, nome do gestor, nome do recrutador) — esses "
   267	            "vêm do contexto autenticado. Se faltar contexto, ofereça TENTAR "
   268	            "DE NOVO ou REVISAR o registrado — NUNCA peça dados de identificação."
   269	        )
   270	        if tenant_snippet:
   271	            sys += f"\n\nContexto do tenant: {tenant_snippet[:400]}"
   272	        user = f"Últimos turnos:\n{tail_text}"
   273	        result = await asyncio.wait_for(
   274	            llm.ainvoke([SystemMessage(content=sys), HumanMessage(content=user)]),
   275	            timeout=timeout_s,
   276	        )
   277	        text = (getattr(result, "content", "") or "").strip()
   278	        # R-008 harness guard (2026-05-19): reject responses that ask for
   279	        # tenant data — regressão B1 anti-pattern (`wizard_no_tenant_leak.jsonl`).
   280	        # Tenant comes from authenticated context, never from chat input.
   281	        _tlow = text.lower() if text else ""
   282	        _tenant_question_patterns = (
   283	            "company_id", "id da empresa", "nome da empresa", "qual o setor",
   284	            "qual a empresa", "qual sua empresa", "qual seu plano",
   285	            "nome do consultor", "nome do gestor", "nome do recrutador",
   286	            "qual o seu nome", "informe a empresa", "qual é a empresa",
   287	        )
   288	        _asks_tenant = any(p in _tlow for p in _tenant_question_patterns)
   289	        if _asks_tenant:
   290	            logger.warning(
   291	                "[WizardSession] fallback LLM tentou perguntar tenant data (stage=%s) "
   292	                "— bloqueado por harness guard e degradado para hard prefix. "
   293	                "Resposta rejeitada (preview): %r",
   294	                stage, text[:120],
   295	            )
   296	        if text and "preciso da sua aprovação" not in _tlow and not _asks_tenant:
   297	            return text[:500]
   298	    except Exception as exc:  # noqa: BLE001 — fallback é fail-open p/ hard prefix
   299	        logger.warning(
   300	            "[WizardSession] fallback LLM falhou (stage=%s): %s — usando hard prefix",
   301	            stage, exc,
   302	        )
   303	    return _build_hard_fallback_message(stage)
