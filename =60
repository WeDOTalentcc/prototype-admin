   421	class WizardSessionService:
   422	    """Manages JobCreationGraph invocation with per-session state accumulation.
   423	
   424	    Fixes Bug 6: conversation_messages are now accumulated across WS turns.
   425	    On Turn N the service pulls the checkpointed state from LangGraph,
   426	    appends the new user message, and re-invokes — so the graph always has
   427	    the full conversation history.
   428	
   429	    Responsibilities
   430	    ────────────────
   431	    - derive_thread_id(): stable session → thread_id mapping
   432	    - _get_prior_state(): non-raising checkpointer read
   433	    - _build_state(): merge or fresh-start state builder
   434	    - process_message(): main entry point for agent_chat_ws.py
   435	
   436	    NOT responsible for: HITL approval routing (stays in agent_chat_ws.py),
   437	    token streaming setup (caller provides on_token callback).
   438	    """
   439	
   440	    # ── Public helpers ────────────────────────────────────────────────────
   441	
   442	    # Task #1080 canonical refactor: the legacy 4-priority ``derive_thread_id``
   443	    # (msg.thread_id custom > company-prefixed > legacy) and the Redis
   444	    # marker bookkeeping (``lia:wizard:active:*``) have been removed. The
   445	    # canonical pure function lives in ``app.shared.sessions.thread_id``
   446	    # and is the SINGLE source of truth across WS / SSE / REST orchestrator.
   447	    # The two thin staticmethods below are delegating wrappers kept for
   448	    # backward compatibility with existing call-sites and tests that mock
   449	    # ``WizardSessionService.derive_thread_id`` / ``.is_session_active``.
   450	
