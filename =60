   926	        try:  # pragma: no cover — exercitado via integração
   927	            from prometheus_client import REGISTRY as _PROM_REGISTRY
   928	            from prometheus_client import Counter as _PromCounter
   929	
   930	            existing = getattr(
   931	                _PROM_REGISTRY, "_names_to_collectors", {},
   932	            ).get("lia_wizard_supervisor_intent_total")
   933	            if existing is None:
   934	                counter = _PromCounter(
   935	                    "lia_wizard_supervisor_intent_total",
   936	                    "Total de intents classificados pelo Wizard Supervisor "
   937	                    "(Task #1127). Label intent ∈ allowlist canônica; "
   938	                    "label stage = current_stage do graph ou 'unstarted'.",
   939	                    labelnames=("intent", "stage"),
   940	                )
   941	            else:
   942	                counter = existing
   943	            counter.labels(intent=intent, stage=stage_label).inc()
   944	        except Exception as pm_exc:  # noqa: BLE001
   945	            logger.debug(
   946	                "[WizardSupervisor] prometheus inc failed (fail-open): %s",
   947	                pm_exc,
   948	            )
   949	
   950	        # Audit row (best-effort)
   951	        cid = str(company_id) if company_id else ""
   952	        if not cid:
   953	            return
