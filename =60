   907	    @staticmethod
   908	    def _emit_supervisor_telemetry(
   909	        *,
   910	        intent: str,
   911	        confidence: float,
   912	        company_id: str | None,
   913	        thread_id: str,
   914	        current_stage: str | None,
   915	    ) -> None:
   916	        """Telemetria fail-OPEN do supervisor (Prometheus + audit).
   917	
   918	        Counter Prometheus ``lia_wizard_supervisor_intent_total``
   919	        (label=intent,stage) e audit row ``decision_type=
   920	        wizard_supervisor_routed`` (SOX 7y) — best-effort, nunca derruba
   921	        o turno.
