   729	    @classmethod
   730	    async def _run_supervisor(
   731	        cls,
   732	        *,
   733	        user_message: str,
   734	        prior_state: dict | None,
   735	        context: dict | None,
   736	        company_id: str | None,
   737	        session_id: str,
   738	        thread_id: str,
   739	    ) -> dict | None:
   740	        """Roda o supervisor pre-graph e devolve decisão de roteamento.
   741	
