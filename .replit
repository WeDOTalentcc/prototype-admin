modules = ["nodejs-20", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["python_gemini_ai_integrations:1.0.0", "python_anthropic_ai_integrations:1.0.0", "jira:1.0.0", "python_openai:1.0.0", "github:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["cargo", "freetype", "glibcLocales", "libiconv", "libyaml", "postgresql", "rustc", "xcodebuild", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "dev-server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "lia-backend"

[[workflows.workflow]]
name = "dev-server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd plataforma-lia && npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "lia-backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd lia-agent-system && python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8000"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 63315
externalPort = 3002

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd lia-agent-system && python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 2 --timeout-keep-alive 30 & cd plataforma-lia && npm start -- -p 5000"]
build = ["bash", "-c", "cd plataforma-lia && npm run build"]

[userenv]

[userenv.shared]
SERVICE_API_TOKEN = "cyHLoZNT2lM9iJkeAbzXLEbHo4fZ9EP24_lMTnbyneo"
USE_REACT_AGENTS = "true"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
