    {
      "type": "text",
      "id": "flow_text",
      "x": 60,
      "y": 1565,
      "width": 1380,
      "height": 80,
      "text": "User types in Prompt → prompt_input.vue sends POST /chat/stream with { message, session_id, domain, context_data: { ui_context, current_path } }\n→ FastAPI → MessageRouter → HubOrchestrator → HubPlanner (fast-path / CostLadder / LLM) → HubExecutor\n→ DomainOrchestrator → DomainWorkflow (LangGraph) → API calls to Rails (ats_api) → response\n→ SSE stream back to frontend → StreamingMessage.vue renders progressively → ExecutionTracker shows steps",
      "originalText": "User types in Prompt → prompt_input.vue sends POST /chat/stream with { message, session_id, domain, context_data: { ui_context, current_path } }\n→ FastAPI → MessageRouter → HubOrchestrator → HubPlanner (fast-path / CostLadder / LLM) → HubExecutor\n→ DomainOrchestrator → DomainWorkflow (LangGraph) → API calls to Rails (ats_api) → response\n→ SSE stream back to frontend → StreamingMessage.vue renders progressively → ExecutionTracker shows steps",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#5b21b6",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 9005,
      "version": 1,
