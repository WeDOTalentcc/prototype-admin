Height":1.25},{"id":"p6_s12_v5_con","type":"text","x":1410,"y":12542,"width":1230,"height":38,"angle":0,"strokeColor":"#334155","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":648451888,"version":1,"versionNonce":935024784,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"• Sem CI/CD documentado — possivelmente testes não rodam automaticamente\n• Sem golden dataset formal — evals/run_evals.py sem dataset de referência","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"• Sem CI/CD documentado — possivelmente testes não rodam automaticamente\n• Sem golden dataset formal — evals/run_evals.py sem dataset de referência","autoResize":true,"lineHeight":1.25},{"id":"p6_s13_bg","type":"rectangle","x":50,"y":12615,"width":2600,"height":30,"angle":0,"strokeColor":"#e8eaf6","backgroundColor":"#e8eaf6","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":645440785,"version":1,"versionNonce":601442069,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s13_title","type":"text","x":60,"y":12620,"width":2580,"height":22,"angle":0,"strokeColor":"#283593","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":21937909,"version":1,"versionNonce":921795386,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"13. JOBS ASSÍNCRONOS & PROCESSAMENTO (Seção 18)","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"13. JOBS ASSÍNCRONOS & PROCESSAMENTO (Seção 18)","autoResize":true,"lineHeight":1.25},{"id":"p6_s13_narrative","type":"text","x":60,"y":12655,"width":2580,"height":57,"angle":0,"strokeColor":"#334155","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":19373774,"version":1,"versionNonce":929164297,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"POR QUE IMPORTA: Jobs scheduled cobrem manutenção automática — sem eles, o sistema acumula lixo, não detecta regressões,\ne não limpa dados expirados. A LIA tem 7+ jobs Celery com beat schedule. O v5 usa RabbitMQ (broker mais robusto — ACK\npersistente, exchange routing) com workers multi-instance via systemd, mas SEM beat schedule e SEM DLQ.","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"POR QUE IMPORTA: Jobs scheduled cobrem manutenção automática — sem eles, o sistema acumula lixo, não detecta regressões,\ne não limpa dados expirados. A LIA tem 7+ jobs Celery com beat schedule. O v5 usa RabbitMQ (broker mais robusto — ACK\npersistente, exchange routing) com workers multi-instance via systemd, mas SEM beat schedule e SEM DLQ.","autoResize":true,"lineHeight":1.25},{"id":"p6_s13_lia_pro_bg","type":"rectangle","x":50,"y":12722,"width":1250,"height":106,"angle":0,"strokeColor":"#e2e8f0","backgroundColor":"#e8f5e9","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":987594098,"version":1,"versionNonce":771238148,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s13_v5_pro_bg","type":"rectangle","x":1400,"y":12722,"width":1250,"height":106,"angle":0,"strokeColor":"#e2e8f0","backgroundColor":"#e3f2fd","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":922680124,"version":1,"versionNonce":601512516,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s13_lia_pro_title","type":"text","x":60,"y":12727,"width":1230,"height":20,"angle":0,"strokeColor":"#2e7d32","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":760411552,"version":1,"versionNonce":29582427,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"✅ LIA — 7+ Jobs Scheduled","fontSize":14,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"✅ LIA — 7+ Jobs Scheduled","autoResize":true,"lineHeight":1.25},{"id":"p6_s13_v5_pro_title","type":"text","x":1410,"y":12727,"width":1230,"height":20,"angle":0,"strokeColor":"#0d47a1","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":55760425,"version":1,"versionNonce":839849290,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"✅ v5 — RabbitMQ + Workers","fontSize":14,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"✅ v5 — RabbitMQ + Workers","autoResize":true,"lineHeight":1.25},{"id":"p6_s13_lia_pro","type":"text","x":60,"y":12747,"width":1230,"height":76,"angle":0,"strokeColor":"#334155","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":972813744,"version":1,"versionNonce":420955277,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"• drift_job (diário), proactive_alerts (horário)\n• lgpd_cleanup (semanal), ab_testing_job (diário)\n• finetuning_export (semanal), learning_loop (diário), memory_job (diário)\n• DLQ com Redis LIST — nenhuma task falha silenciosamente","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText