gle","x":50,"y":12976,"width":2600,"height":30,"angle":0,"strokeColor":"#e8eaf6","backgroundColor":"#e8eaf6","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":599907182,"version":1,"versionNonce":722868379,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s14_title","type":"text","x":60,"y":12981,"width":2580,"height":22,"angle":0,"strokeColor":"#283593","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":317790581,"version":1,"versionNonce":337733961,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"14. INVENTÁRIO DE ARQUIVOS & COBERTURA DE DOMÍNIOS (Seções 19, 22)","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"14. INVENTÁRIO DE ARQUIVOS & COBERTURA DE DOMÍNIOS (Seções 19, 22)","autoResize":true,"lineHeight":1.25},{"id":"p6_s14_narrative","type":"text","x":60,"y":13016,"width":2580,"height":57,"angle":0,"strokeColor":"#334155","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":61348487,"version":1,"versionNonce":992956194,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"POR QUE IMPORTA: O mapa de cobertura mostra onde cada sistema é forte e onde tem gaps. A LIA está à frente em: multi-tenancy,\nLGPD, FairnessGuard, learning loop, LLM multi-provider, OTEL + Prometheus, volume de testes (313 vs 96), cobertura de domínios\n(12 vs 8). O v5 está à frente em: RabbitMQ, autonomous ReAct com 73+ tools, 9 subagentes sourcing, injection protection, TenantMemoryStore.","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"POR QUE IMPORTA: O mapa de cobertura mostra onde cada sistema é forte e onde tem gaps. A LIA está à frente em: multi-tenancy,\nLGPD, FairnessGuard, learning loop, LLM multi-provider, OTEL + Prometheus, volume de testes (313 vs 96), cobertura de domínios\n(12 vs 8). O v5 está à frente em: RabbitMQ, autonomous ReAct com 73+ tools, 9 subagentes sourcing, injection protection, TenantMemoryStore.","autoResize":true,"lineHeight":1.25},{"id":"p6_s14_table_bg","type":"rectangle","x":50,"y":13086,"width":2600,"height":390,"angle":0,"strokeColor":"#e2e8f0","backgroundColor":"#f5f5f5","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":554454108,"version":1,"versionNonce":658598709,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s14_table","type":"text","x":65,"y":13096,"width":2570,"height":342,"angle":0,"strokeColor":"#334155","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":450422402,"version":1,"versionNonce":859425646,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"FUNCIONALIDADE                    LIA                           v5\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nCRUD de Vagas                     ✅ Job Management              ✅ Jobs domain\nPipeline de Candidatos            ✅ CV Screening + Pipeline      ✅ Applies domain\nSourcing de Talentos              ✅ 1 agente                    ✅ 9 subagentes\nAgendamento Entrevistas           ✅ InterviewGraph              ✅ SchedulingGraph\nAvaliações / WSI                  ✅ WSIInterviewGraph           ✅ InterviewGraph\nMétricas / Insights               ✅ Analytics domain            ✅ Insights domain\nComunicação (Email)               ✅ Communication               ✅ Messaging\nPolicy / Compliance               ✅ Policy domain (Z5-02)       ❌ Não existe\nLGPD Compliance                   ✅ lgpd_cleanup + DSR          ❌ Sem compliance\nFairness 3 camadas                ✅ FairnessGuard obrig.        ⚠ Opt-in 2 dom.\nMulti-tenancy no agente           ✅ Budget + guardrails         ❌ Rails gerencia\nLearning Loop                     ✅ Ciclo completo              ⚠ Só feedback save\nLLM Multi-provider                ✅ Claude+Gemini+GPT           ❌ Gemini único\nOTEL / Prometheus                 ✅ OTEL (Z6-02)               ❌ Sem metrics\nInjection Protection              Implícita                     ✅ security.py (20+)\nRabbitMQ                          ❌ Redis broker                ✅ RabbitMQ nativo\nAutonomous ReAct                  ⚠ Via domínios                ✅ 73+ tools","fontSize":12,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"FUNCIONALIDADE                    LIA                           v5\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nCRUD de Vagas                     ✅ Job Management              ✅ Jobs domain\nPipeline de Candidatos            ✅ CV Screening + Pipeline      ✅ Applies domain\nSourcing de Talentos              ✅ 1 agente                    ✅ 9 subagentes\nAgendamento Entrevistas           ✅ InterviewGraph              ✅ SchedulingGraph\nAvaliações / WSI                  ✅ WSIInterviewGraph           ✅ InterviewGraph\nMétricas / Insights               ✅ Analytics domain            ✅ Insights domain\nComunicação (Email)               ✅ Communication               ✅ Messaging\nPolicy / Compliance               ✅ Policy domain (Z5-02)       ❌ Não existe\nLGPD Compliance                   ✅ lgpd_cleanup + DSR          ❌ Sem compliance\nFairness 3 camadas                ✅ FairnessGuard obrig.        ⚠ Opt-in 2 dom.\nMulti-tenancy no agente           ✅ Budget + guardrails         ❌ Rails gerencia\nLearning Loop                     ✅ Ciclo completo              ⚠ Só feedback save\nLLM Multi-provider                ✅ Claude+Gemini+GPT           ❌ Gemini único\nOTEL / Prometheus                 ✅ OTEL (Z6-02)               ❌ Sem metrics\nInjection Protection              Implícita                     ✅ security.py (20+)\nRabbitMQ                          ❌ Redis broker                ✅ RabbitMQ nativo\nAutonomous ReAct                  ⚠ Via domínios                ✅ 73+ tools","autoResize":true,"lineHeight":1.25},{"id":"p6_s15_bg","type":"rectangle","x":50,"y":13496,"width":2600,"height":30,"angle":0,"strokeColor":"#ff6f00","backgroundColor":"#ff6f00","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":531404453,"version":1,"versionNonce":511503194,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s15_title","type":"text","x":60,"y":13501,"width":2580,"height":22,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":516426136,"version":1,"versionNonce":120935931,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"15. AGENT STUDIO — COMPARATIVO LIA vs v5 & CRÍTICA DE ESCALABILIDADE","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"15. AGENT STUDIO — COMPARATIVO LIA vs v5 & CRÍTICA DE ESCALABILIDADE","autoResize":true,"lineHeight":1.25},{"id":"p6_s15_narrative","type":"text","x":60,"y":13536,"width":2580,"height":95,"angle":0,"strokeColor":"#334155","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":198087766,"version":1,"versionNonce":290829648,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"POR QUE IMPORTA: Agent Studio é a capacidade de clientes criarem e configurarem seus próprios agentes sem intervenção do time\nde engenharia. Eightfold (Project Andromeda) e Phenom (X+ Studio) já oferecem isso. A diferença fundamental: a LIA tem infraestrutura\ncompartilhada (EnhancedAgentMixin, PromptRegistry, FairnessGuard como herança) que torna cada novo agente automaticamente compliant\n— 0 linhas de implementação por agente. O v5 tem domínios autocontidos sem camada shared real, o que significa que criar um novo\nagente exige reimplementar fairness, memory, prompts manualmente — replicação de código desnecessária que NÃO escala.","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"POR QUE IMPORTA: Agent Studio é a capacidade de clientes criarem e configurarem seus próprios agentes sem intervenção do time\nde engenharia. Eightfold (Project Andromeda) e Phenom (X+ Studio) já oferecem isso. A diferença fundamental: a LIA tem infraestrutura\ncompartilhada (EnhancedAgentMixin, PromptRegistry, FairnessGuard como herança) que torna cada novo agente automaticamente compliant\n— 0 linhas de implementação por agente. O v5 tem domínios autocontidos sem camada shared real, o que significa que criar um novo\nagente exige reimplementar fairness, memory, prompts manualmente — replicação de código desnecessária que NÃO escala.","autoResize":true,"lineHeight":1.25},{"id":"p6_s15_critique_bg","type":"rectangle","x":50,"y":13646,"width":2600,"height":140,"angle":0,"strokeColor":"#ff6f00","backgroundColor":"#fff3e0","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":804591040,"version":1,"versionNonce":801793040,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s15_critique","type":"text","x":65,"y":13656,"width":2570,"height":133,"angle":0,"strokeColor":"#e65100","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":898787838,"version":1,"versionNonce":876954858,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"CRÍTICA ARQUITETURAL — Escalabilidade do v5 para Agent Studio:\nCada domínio do v5 implementa seus próprios prompts.py, fairness.py, memory.py, actions/ de forma isolada.\nNão existe src/shared/ com base classes que garantam comportamento padrão. Para um cliente que vai criar vários\nagentes via Agent Studio, isso resulta em: (1) duplicação de código de fairness, memory e prompts em cada agente\nnovo, (2) impossibilidade de adicionar features transversais (ex: anti-sycophancy) sem modificar N arquivos em\nN domínios manualmente, (3) risco de agentes novos não terem compliance porque não há herança automática.\nNa LIA, EnhancedAgentMixin resolve isso — qualquer novo agente herda FairnessGuard, tracing, compliance com 0 linhas.","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"CRÍTICA ARQUITETURAL — Escalabilidade do v5 para Agent Studio:\nCada domínio do v5 implementa seus próprios prompts.py, fairness.py, memory.py, actions/ de forma isolada.\nNão existe src/shared/ com base classes que garantam comportamento padrão. Para um cliente que vai criar vários\nagentes via Agent Studio, isso resulta em: (1) duplicação de código de fairness, memory e prompts em cada agente\nnovo, (2) impossibilidade de adicionar features transversais (ex: anti-sycophancy) sem modificar N arquivos em\nN domínios manualmente, (3) risco de agentes novos não terem compliance porque não há herança automática.\nNa LIA, EnhancedAgentMixin resolve isso — qualquer novo agente herda FairnessGuard, tracing, compliance com 0 linhas.","autoResize":true,"lineHeight":1.25},{"id":"p6_s15_table_bg","type":"rectangle","x":50,"y":13806,"width":2600,"height":250,"angle":0,"strokeColor":"#e2e8f0","backgroundColor":"#fff3e0","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":470326192,"version":1,"versionNonce":159336751,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s15_table","type":"text","x":65,"y":13816,"width":2570,"height":216,"angle":0,"strokeColor":"#334155","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":214888919,"version":1,"versionNonce":809209838,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"DIMENSÃO                          LIA                                       v5\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nTenant ID no sistema              company_id flui em TODOS componentes       workspace_id existe mas não personaliza\nBase para override de prompt      PromptRegistry + get_tenant_prompt()       get_system_prompt() abstrato + proxy decorator\nBase para filtro de tools         tool_registry_metadata.yaml + tenant dim   Tools por domínio — interceptar antes do grafo\nOnde vive a config                DB LIA (PostgreSQL local, SQLAlchemy)      DB Rails (ats_api) — acesso via HTTP\nCache                             Redis (TenantBudget usa mesmo padrão)      Redis (TenantMemoryStore mesmo padrão)\nESCALABILIDADE NOVOS AGENTES      ✅ EnhancedAgentMixin: 0 linhas/agente    ❌ Sem shared/: reimplementar fairness, memory\nComplexidade implementação        ⭐⭐ Moderada — infra tenant já madura      ⭐⭐⭐ Alta — nunca foi multi-tenant\nRisco de regressão                Baixo — override é aditivo (suffix)       Médio — proxy _TenantOverrideDomain\nTempo estimado (backend)          ~2 semanas (2 sprints backend)            ~2.5 semanas (1.5 sprint Python + 1 Rails)\nDependência de outro time         Não — tudo na LIA                         Sim — precisa endpoint Rails + migration","fontSize":12,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"DIMENSÃO                          LIA                                       v5\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nTenant ID no sistema              company_id flui em TODOS componentes       workspace_id existe mas não personaliza\nBase para override de prompt      PromptRegistry + get_tenant_prompt()       get_system_prompt() abstrato + proxy decorator\nBase para filtro de tools         tool_registry_metadata.yaml + tenant dim   Tools por domínio — interceptar antes do grafo\nOnde vive a config                DB LIA (PostgreSQL local, SQLAlchemy)      DB Rails (ats_api) — acesso via HTTP\nCache                             Redis (TenantBudget usa mesmo padrão)      Redis (TenantMemoryStore mesmo padrão)\nESCALABILIDADE NOVOS AGENTES      ✅ EnhancedAgentMixin: 0 linhas/agente    ❌ Sem shared/: reimplementar fairness, memory\nComplexidade implementação        ⭐⭐ Moderada — infra tenant já madura      ⭐⭐⭐ Alta — nunca foi multi-tenant\nRisco de regressão                Baixo — override é aditivo (suffix)       Médio — proxy _TenantOverrideDomain\nTempo estimado (backend)          ~2 semanas (2 sprints backend)            ~2.5 semanas (1.5 sprint Python + 1 Rails)\nDependência de outro time         Não — tudo na LIA                         Sim — precisa endpoint Rails + migration","autoResize":true,"lineHeight":1.25},{"id":"p6_s15_lia_plan","type":"text","x":60,"y":14076,"width":1230,"height":133,"angle":0,"strokeColor":"#334155","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":623651861,"version":1,"versionNonce":349336416,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"Plano LIA (6 passos):\n(1) Tabela tenant_agent_configs (migration SQL)\n(2) TenantAgentConfigService (DB + Redis cache TTL 5min)\n(3) Integrar override no PromptRegistry via get_tenant_prompt()\n(4) filter_tools_for_tenant() no tool_registry_loader.py\n(5) Endpoint POST /api/v1/admin/agents/configure\n(6) Hook no main_orchestrator.py para injetar config","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Plano LIA (6 passos):\n(1) Tabela tenant_agent_configs (migration SQL)\n(2) TenantAgentConfigService (DB + Redis cache TTL 5min)\n(3) Integrar override no PromptRegistry via get_tenant_prompt()\n(4) filter_tools_for_tenant() no tool_registry_loader.py\n(5) Endpoint POST /api/v1/admin/agents/configure\n(6) Hook no main_orchestrator.py para injetar config","autoResize":true,"lineHeight":1.25},{"id":"p6_s15_v5_plan","type":"text","x":1410,"y":14076,"width":1230,"height":133,"angle":0,"strokeColor":"#334155","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":94457595,"version":1,"versionNonce":156803331,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"Plano v5 (5 passos):\n(1) TenantConfigLoader em src/hub/tenant_config.py\n    (chama Rails API + Redis cache)\n(2) Filtrar domínios no DomainCatalog por tenant\n(3) Override de prompt via proxy _TenantOverrideDomain\n(4) Propagar workspace_id obrigatório no api.py\n(5) Endpoint de configuração no Rails (migration + model)","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Plano v5 (5 passos):\n(1) TenantConfigLoader em src/hub/tenant_config.py\n    (chama Rails API + Redis cache)\n(2) Filtrar domínios no DomainCatalog por tenant\n(3) Override de prompt via proxy _TenantOverrideDomain\n(4) Propagar workspace_id obrigatório no api.py\n(5) Endpoint de configuração no Rails (migration + model)","autoResize":true,"lineHeight":1.25},{"id":"p6_s15_rec_bg","type":"rectangle","x":50,"y":14236,"width":2600,"height":60,"angle":0,"strokeColor":"#2e7d32","backgroundColor":"#e8f5e9","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":178253639,"version":1,"versionNonce":633909412,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s15_rec","type":"text","x":65,"y":14246,"width":2570,"height":57,"angle":0,"strokeColor":"#1b5e20","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":618802453,"version":1,"versionNonce":965247129,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"RECOMENDAÇÃO: Implementar na LIA primeiro (menor risco, infra madura, sem dependência de outro time, escalabilidade\ngarantida via EnhancedAgentMixin), validar com 2-3 clientes, portar aprendizado para v5. O v5 precisa ANTES criar\nsrc/shared/ com base classes para fairness, memory e prompts — caso contrário, cada agente novo = cópia sem compliance.","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"RECOMENDAÇÃO: Implementar na LIA primeiro (menor risco, infra madura, sem dependência de outro time, escalabilidade\ngarantida via EnhancedAgentMixin), validar com 2-3 clientes, portar aprendizado para v5. O v5 precisa ANTES criar\nsrc/shared/ com base classes para fairness, memory e prompts — caso contrário, cada agente novo = cópia sem compliance.","autoResize":true,"lineHeight":1.25},{"id":"p6_s16_bg","type":"rectangle","x":50,"y":14316,"width":2600,"height":30,"angle":0,"strokeColor":"#1565c0","backgroundColor":"#1565c0","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":915875329,"version":1,"versionNonce":266546577,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s16_title","type":"text","x":60,"y":14321,"width":2580,"height":22,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":830858815,"version":1,"versionNonce":617431555,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"16. PLANOS DE OTIMIZAÇÃO — RECOMENDAÇÕES PRIORITÁRIAS (Seções 20-21)","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"16. PLANOS DE OTIMIZAÇÃO — RECOMENDAÇÕES PRIORITÁRIAS (Seções 20-21)","autoResize":true,"lineHeight":1.25},{"id":"p6_s16_lia_bg","type":"rectangle","x":50,"y":14356,"width":1250,"height":370,"angle":0,"strokeColor":"#e2e8f0","backgroundColor":"#e3f2fd","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":478658827,"version":1,"versionNonce":715182541,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s16_v5_bg","type":"rectangle","x":1400,"y":14356,"width":1250,"height":370,"angle":0,"strokeColor":"#e2e8f0","backgroundColor":"#e3f2fd","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":263446528,"version":1,"versionNonce":296000808,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s16_lia","type":"text","x":60,"y":14366,"width":1230,"height":285,"angle":0,"strokeColor":"#0d47a1","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":812358487,"version":1,"versionNonce":242395263,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"RECOMENDAÇÕES LIA (10 itens, 2 fases)\n\nALTA PRIORIDADE:\nL-01: TTL em working_memory (90d + cleanup automático)\nL-02: Relatório fairness exportável (PDF para auditores NYC LL144)\nL-03: Red teaming FairnessGuard (dataset adversarial + CI test)\nL-04: Cobertura testes 30% → 50% nos domínios críticos\nL-05: Prompts .py → .yaml (customização sem deploy)\n\nMÉDIO PRAZO:\nL-06: Agent Studio (POST /api/v1/agents/configure com tenant override)\nL-07: Criptografia PII (pgcrypto para CPF/email no PostgreSQL)\nL-08: Avaliar LiteLLM vs llm_factory.py para cascade\nL-09: Expandir RAGAS para avaliar agente (tool selection, plan correctness)\nL-10: Migrar broker Redis → RabbitMQ (mais robusto em produção)","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"RECOMENDAÇÕES LIA (10 itens, 2 fases)\n\nALTA PRIORIDADE:\nL-01: TTL em working_memory (90d + cleanup automático)\nL-02: Relatório fairness exportável (PDF para auditores NYC LL144)\nL-03: Red teaming FairnessGuard (dataset adversarial + CI test)\nL-04: Cobertura testes 30% → 50% nos domínios críticos\nL-05: Prompts .py → .yaml (customização sem deploy)\n\nMÉDIO PRAZO:\nL-06: Agent Studio (POST /api/v1/agents/configure com tenant override)\nL-07: Criptografia PII (pgcrypto para CPF/email no PostgreSQL)\nL-08: Avaliar LiteLLM vs llm_factory.py para cascade\nL-09: Expandir RAGAS para avaliar agente (tool selection, plan correctness)\nL-10: Migrar broker Redis → RabbitMQ (mais robusto em produção)","autoResize":true,"lineHeight":1.25},{"id":"p6_s16_v5","type":"text","x":1410,"y":14366,"width":1230,"height":399,"angle":0,"strokeColor":"#0d47a1","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":12369478,"version":1,"versionNonce":246470043,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"RECOMENDAÇÕES v5 (14 itens, 3 fases)\n\nFASE V-1 CRÍTICO (Sprint 1-2):\nV-01: Estabilizar PostgresSaver (pool dedicado + retry tenacity)\nV-02: Multi-tenancy básico no Hub (TenantContext + workspace_id)\nV-03: Criar src/shared/fairness/ unificado (eliminar duplicação cross-domain)\nV-04: PII masking em PROMPTS (não só logs — Gemini recebe CPFs)\nV-05: Resolver referências pronominais no HubPlanner\n\nFASE V-2 ALTA (Sprint 3-4):\nV-06: Tool registry explícito por domínio (auditoria + testes)\nV-07: Anti-sycophancy em todos os prompts de sistema\nV-08: DLQ para RabbitMQ (dead letter exchange)\nV-09: Prometheus metrics (request_count, latency, tokens, circuit)\nV-10: Feedback loop básico (webhook Rails→v5 + análise semanal)\n\nFASE V-3 MÉDIO (Sprint 5-8):\nV-11: Relatório fairness exportável (JSON/CSV)\nV-12: Golden dataset + DeepEval (50 perguntas canônicas)\nV-13: Pipeline CI/CD (.github/workflows/tests.yml)\nV-14: Agent Studio (precisa de src/shared/ ANTES)","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"RECOMENDAÇÕES v5 (14 itens, 3 fases)\n\nFASE V-1 CRÍTICO (Sprint 1-2):\nV-01: Estabilizar PostgresSaver (pool dedicado + retry tenacity)\nV-02: Multi-tenancy básico no Hub (TenantContext + workspace_id)\nV-03: Criar src/shared/fairness/ unificado (eliminar duplicação cross-domain)\nV-04: PII masking em PROMPTS (não só logs — Gemini recebe CPFs)\nV-05: Resolver referências pronominais no HubPlanner\n\nFASE V-2 ALTA (Sprint 3-4):\nV-06: Tool registry explícito por domínio (auditoria + testes)\nV-07: Anti-sycophancy em todos os prompts de sistema\nV-08: DLQ para RabbitMQ (dead letter exchange)\nV-09: Prometheus metrics (request_count, latency, tokens, circuit)\nV-10: Feedback loop básico (webhook Rails→v5 + análise semanal)\n\nFASE V-3 MÉDIO (Sprint 5-8):\nV-11: Relatório fairness exportável (JSON/CSV)\nV-12: Golden dataset + DeepEval (50 perguntas canônicas)\nV-13: Pipeline CI/CD (.github/workflows/tests.yml)\nV-14: Agent Studio (precisa de src/shared/ ANTES)","autoResize":true,"lineHeight":1.25},{"id":"p6_s17_bg","type":"rectangle","x":50,"y":14746,"width":2600,"height":30,"angle":0,"strokeColor":"#4a148c","backgroundColor":"#4a148c","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":663203684,"version":1,"versionNonce":331074629,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s17_title","type":"text","x":60,"y":14751,"width":2580,"height":22,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":397923723,"version":1,"versionNonce":995924924,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"17. TIPOS DE AGENTES DO MERCADO & COMO CONSTRUIR NA WEDOTALENT (Parte 3)","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"17. TIPOS DE AGENTES DO MERCADO & COMO CONSTRUIR NA WEDOTALENT (Parte 3)","autoResize":true,"lineHeight":1.25},{"id":"p6_s17_table_bg","type":"rectangle","x":50,"y":14786,"width":2600,"height":160,"angle":0,"strokeColor":"#e2e8f0","backgroundColor":"#ede7f6","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":523171496,"version":1,"versionNonce":573753954,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s17_table","type":"text","x":65,"y":14796,"width":2570,"height":126,"angle":0,"strokeColor":"#334155","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":268721628,"version":1,"versionNonce":333856639,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"TIPO DE AGENTE              REFERÊNCIA DE MERCADO                          VIABILIDADE LIA                    VIABILIDADE v5\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nDigital Twins               Eightfold Project Andromeda — corpus SME         Alta — voice_service + pgv_analyzer  Média — embed+RAG, sem corpus SME\nMulti-Agent Sourcing        Juicebox Agents 2.0 — agentes paralelos         Média — 1 SourcingReActAgent         Alta — 9 subagentes já prontos\nAgentes por Setor/Template  Phenom X+ Studio — templates por indústria      Alta — sector_context + Mixin        ❌ Baixa — sem shared/, duplicação\nGuided Autonomy             hireEZ EZ Agent — autonomia + guardrails        Alta — autonomy_engine.py + HITL     Média — autonomous, HITL não obrig.\nAgente de Voz p/ Triagem    Phenom/Paradox — voz com scoring real-time      Alta — gemini_voice + WSIGraph       Baixa — sem voz, sem grafo voz","fontSize":12,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"TIPO DE AGENTE              REFERÊNCIA DE MERCADO                          VIABILIDADE LIA                    VIABILIDADE v5\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nDigital Twins               Eightfold Project Andromeda — corpus SME         Alta — voice_service + pgv_analyzer  Média — embed+RAG, sem corpus SME\nMulti-Agent Sourcing        Juicebox Agents 2.0 — agentes paralelos         Média — 1 SourcingReActAgent         Alta — 9 subagentes já prontos\nAgentes por Setor/Template  Phenom X+ Studio — templates por indústria      Alta — sector_context + Mixin        ❌ Baixa — sem shared/, duplicação\nGuided Autonomy             hireEZ EZ Agent — autonomia + guardrails        Alta — autonomy_engine.py + HITL     Média — autonomous, HITL não obrig.\nAgente de Voz p/ Triagem    Phenom/Paradox — voz com scoring real-time      Alta — gemini_voice + WSIGraph       Baixa — sem voz, sem grafo voz","autoResize":true,"lineHeight":1.25},{"id":"p6_s18_bg","type":"rectangle","x":50,"y":14966,"width":2600,"height":30,"angle":0,"strokeColor":"#4a148c","backgroundColor":"#4a148c","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":318786210,"version":1,"versionNonce":622629847,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s18_title","type":"text","x":60,"y":14971,"width":2580,"height":22,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":706834209,"version":1,"versionNonce":763017514,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"18. REFERÊNCIAS DE MERCADO INTEGRADAS (13 Plataformas)","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"18. REFERÊNCIAS DE MERCADO INTEGRADAS (13 Plataformas)","autoResize":true,"lineHeight":1.25},{"id":"p6_s18_table_bg","type":"rectangle","x":50,"y":15006,"width":2600,"height":340,"angle":0,"strokeColor":"#e2e8f0","backgroundColor":"#f5f5f5","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":366041636,"version":1,"versionNonce":788494228,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s18_table","type":"text","x":65,"y":15016,"width":2570,"height":270,"angle":0,"strokeColor":"#334155","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":794436,"version":1,"versionNonce":351968564,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"PLATAFORMA          RELEVÂNCIA                                                    REFERÊNCIA ARQUITETURAL\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nEightfold AI        Deep-learning matching, bias detection, Digital Twins           LIA FairnessGuard + learning loop; Twins via voice_service\nPhenom People       Orchestration CRM+ATS+AI, multi-tenant, X+ Studio              LIA CascadedRouter + multi-tenancy + EnhancedAgentMixin\nHireVue             Video interview AI, multado por falta de fairness (NYC LL144)   LIA FairnessGuard pre-decision evita erro do HireVue\nParadox (Olivia)    Conversational AI + scheduling, pipeline simples                v5 SchedulingGraph + autonomous ReAct alinhado\nGreenhouse          Structured hiring, API-first, webhooks                          v5 51 YAMLs de API = API-first\nAshby               Analytics-driven, ~800 arquivos, cobertura testes 70%+          LIA analytics + ai_consumption; v5 integration/ 5 níveis\nWorkday Recruit     Enterprise multi-tenancy, compliance por jurisdição             LIA tenant_budget + policy domain = compliance similar\nhireEZ              AI sourcing, Boolean Builder AI, EZ Agent (guided autonomy)     v5 9 subagentes sourcing; LIA autonomy_engine\nSeekOut             Diversity recruiting + talent analytics, skills-based           LIA FairnessGuard + analytics + talent intelligence\nJuicebox            People search + AI enrichment, Agents 2.0                       v5 embedding_service + RAG híbrido + 9 subagentes\nBeamery             CRM talent + talent graphs, AI-driven talent pools              v5 TenantMemoryStore + LIA LongTermMemory\nSmartRecruiters     Multi-channel sourcing, marketplace AI, compliance global       LIA sourcing + v5 subagentes; LIA compliance superior\nFetcher             Automated outbound recruiting, AI email sequences               v5 proactive/ + LIA communication domain","fontSize":12,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"PLATAFORMA          RELEVÂNCIA                                                    REFERÊNCIA ARQUITETURAL\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nEightfold AI        Deep-learning matching, bias detection, Digital Twins           LIA FairnessGuard + learning loop; Twins via voice_service\nPhenom People       Orchestration CRM+ATS+AI, multi-tenant, X+ Studio              LIA CascadedRouter + multi-tenancy + EnhancedAgentMixin\nHireVue             Video interview AI, multado por falta de fairness (NYC LL144)   LIA FairnessGuard pre-decision evita erro do HireVue\nParadox (Olivia)    Conversational AI + scheduling, pipeline simples                v5 SchedulingGraph + autonomous ReAct alinhado\nGreenhouse          Structured hiring, API-first, webhooks                          v5 51 YAMLs de API = API-first\nAshby               Analytics-driven, ~800 arquivos, cobertura testes 70%+          LIA analytics + ai_consumption; v5 integration/ 5 níveis\nWorkday Recruit     Enterprise multi-tenancy, compliance por jurisdição             LIA tenant_budget + policy domain = compliance similar\nhireEZ              AI sourcing, Boolean Builder AI, EZ Agent (guided autonomy)     v5 9 subagentes sourcing; LIA autonomy_engine\nSeekOut             Diversity recruiting + talent analytics, skills-based           LIA FairnessGuard + analytics + talent intelligence\nJuicebox            People search + AI enrichment, Agents 2.0                       v5 embedding_service + RAG híbrido + 9 subagentes\nBeamery             CRM talent + talent graphs, AI-driven talent pools              v5 TenantMemoryStore + LIA LongTermMemory\nSmartRecruiters     Multi-channel sourcing, marketplace AI, compliance global       LIA sourcing + v5 subagentes; LIA compliance superior\nFetcher             Automated outbound recruiting, AI email sequences               v5 proactive/ + LIA communication domain","autoResize":true,"lineHeight":1.25},{"id":"p6_s19_bg","type":"rectangle","x":50,"y":15366,"width":2600,"height":30,"angle":0,"strokeColor":"#1b5e20","backgroundColor":"#1b5e20","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":711897580,"version":1,"versionNonce":880539355,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s19_title","type":"text","x":60,"y":15371,"width":2580,"height":22,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":471584090,"version":1,"versionNonce":822354354,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"19. SCORECARD FINAL — LIA vs v5 por Dimensão (22 Seções Consolidadas)","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"19. SCORECARD FINAL — LIA vs v5 por Dimensão (22 Seções Consolidadas)","autoResize":true,"lineHeight":1.25},{"id":"p6_s19_table_bg","type":"rectangle","x":50,"y":15406,"width":2600,"height":440,"angle":0,"strokeColor":"#e2e8f0","backgroundColor":"#f1f8e9","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":223062185,"version":1,"versionNonce":131040419,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s19_table","type":"text","x":65,"y":15416,"width":2570,"height":342,"angle":0,"strokeColor":"#334155","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":501411091,"version":1,"versionNonce":563060778,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"DIMENSÃO                            LIA                    v5                     VENCEDOR\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nCobertura de domínios               12                     8                      ✅ LIA\nMulti-tenancy no agente             Budget+guardrails      Rails-only             ✅ LIA\nLGPD compliance                     4 serviços             Inexistente            ✅ LIA\nFairnessGuard                       3 camadas obrig.       2 dom. opt-in          ✅ LIA\nLearning loop                       Ciclo completo         Só feedback save       ✅ LIA\nLLM multi-provider                  Claude+Gemini+GPT      Gemini único           ✅ LIA\nObservabilidade                     OTEL+Prometheus        Audit callback         ✅ LIA\nTestes de IA                        313 arquivos           96 arquivos            ✅ LIA\nEscalabilidade Agent Studio         EnhancedAgentMixin     Sem shared/            ✅ LIA\nPrompts customizáveis               YAML + override        Hardcoded .py          ✅ LIA\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nBroker mensageria                   Redis                  RabbitMQ               ✅ v5\nAgente autônomo ReAct               Via domínios           73+ tools              ✅ v5\nSourcing granularidade              1 agente               9 subagentes           ✅ v5\nInjection protection                Implícita              20+ padrões            ✅ v5\nMemória cross-session               LongTermMemory         TTL+dedup+500          ✅ v5\nDynamic prompt building             Estático               AppliesDynamic         ✅ v5","fontSize":12,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"DIMENSÃO                            LIA                    v5                     VENCEDOR\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nCobertura de domínios               12                     8                      ✅ LIA\nMulti-tenancy no agente             Budget+guardrails      Rails-only             ✅ LIA\nLGPD compliance                     4 serviços             Inexistente            ✅ LIA\nFairnessGuard                       3 camadas obrig.       2 dom. opt-in          ✅ LIA\nLearning loop                       Ciclo completo         Só feedback save       ✅ LIA\nLLM multi-provider                  Claude+Gemini+GPT      Gemini único           ✅ LIA\nObservabilidade                     OTEL+Prometheus        Audit callback         ✅ LIA\nTestes de IA                        313 arquivos           96 arquivos            ✅ LIA\nEscalabilidade Agent Studio         EnhancedAgentMixin     Sem shared/            ✅ LIA\nPrompts customizáveis               YAML + override        Hardcoded .py          ✅ LIA\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nBroker mensageria                   Redis                  RabbitMQ               ✅ v5\nAgente autônomo ReAct               Via domínios           73+ tools              ✅ v5\nSourcing granularidade              1 agente               9 subagentes           ✅ v5\nInjection protection                Implícita              20+ padrões            ✅ v5\nMemória cross-session               LongTermMemory         TTL+dedup+500          ✅ v5\nDynamic prompt building             Estático               AppliesDynamic         ✅ v5","autoResize":true,"lineHeight":1.25},{"id":"p6_footer","type":"text","x":50,"y":15866,"width":2600,"height":57,"angle":0,"strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":751352649,"version":1,"versionNonce":52755420,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"Verificado contra codebase real: lia-agent-system/ (1.259 py, 12 domínios, 66 tools, 25 circuit breaker files) +\nrecruiter_agent_v5 (820 py, 8 domínios, 73+ tools, 9 sourcing subagentes) | Documento referência: 5.687 linhas, 22 seções\n+ Agent Studio comparative + Digital Twins (Parte 3) | Verificação: 29/03/2026","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Verificado contra codebase real: lia-agent-system/ (1.259 py, 12 domínios, 66 tools, 25 circuit breaker files) +\nrecruiter_agent_v5 (820 py, 8 domínios, 73+ tools, 9 sourcing subagentes) | Documento referência: 5.687 linhas, 22 seções\n+ Agent Studio comparative + Digital Twins (Parte 3) | Verificação: 29/03/2026","autoResize":true,"lineHeight":1.25},{"id":"cmp_title_bg","type":"rectangle","x":50,"y":5580,"width":2600,"height":30,"angle":0,"strokeColor":"#7c3aed","backgroundColor":"#7c3aed","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":74110498,"version":1,"versionNonce":981982125,"isDeleted":false,"boundElements":null,"updated":1774820769816,"link":null,"locked":false},{"id":"cmp_title","type":"text","x":60,"y":5585,"width":2580,"height":22,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":19549871,"version":1,"versionNonce":439278650,"isDeleted":false,"boundElements":null,"updated":1774820769816,"link":null,"locked":false,"text":"VEREDICTO COMPARATIVO POR DIMENSÃO — v5 vs LIA","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"VEREDICTO COMPARATIVO POR DIMENSÃO — v5 vs LIA","autoResize":true,"lineHeight":1.25},{"id":"cmp_table_bg","type":"rectangle","x":50,"y":5620,"width":2600,"height":270,"angle":0,"strokeColor":"#e2e8f0","backgroundColor":"#f5f0ff","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":669518655,"version":1,"versionNonce":182767092,"isDeleted":false,"boundElements":null,"updated":1774820769816,"link":null,"locked":false},{"id":"cmp_table","type":"text","x":65,"y":5630,"width":2570,"height":216,"angle":0,"strokeColor":"#334155","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":39467527,"version":1,"versionNonce":945420628,"isDeleted":false,"boundElements":null,"updated":1774820769816,"link":null,"locked":false,"text":"DIMENSÃO                           v5                                        LIA                                       VENCEDOR\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nCompliance garantido               Opt-in, não exercido em 75%               Herança obrigatória                       ✅ LIA\nConsistência arquitetural          3 grupos coexistentes                     1 padrão unificado                        ✅ LIA\nObservabilidade                    Manual, logs texto plano                  ReActObserver + Prometheus                ✅ LIA\nParalelismo de agentes             asyncio.gather (Grupo 3)                  Sequential (ReAct cycle)                  ✅ v5\nRoteamento dinâmico LLM            ModelRouter dinâmico                      Circuit breaker estático                  ✅ v5\nLatência caminho simples           50-200ms                                  2-10s                                     ✅ v5\nSeparação dados/IA                 HTTP → Rails (fronteira clara)            SQL direto nos agents                     ✅ v5\nCusto 9º domínio                   Reimplementa compliance (0L real)         0 linhas (herdado)                        ✅ LIA\nLearning Loop                      tracker.py básico (88L)                   1137L + A/B + fairness gate               ✅ LIA\nGuardrails em produção             Hardcoded, requer deploy                  DB editável, efeito imediato              ✅ LIA","fontSize":12,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"DIMENSÃO                           v5                                        LIA                                       VENCEDOR\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nCompliance garantido               Opt-in, não exercido em 75%               Herança obrigatória                       ✅ LIA\nConsistência arquitetural          3 grupos coexistentes                     1 padrão unificado                        ✅ LIA\nObservabilidade                    Manual, logs texto plano                  ReActObserver + Prometheus                ✅ LIA\nParalelismo de agentes             asyncio.gather (Grupo 3)                  Sequential (ReAct cycle)                  ✅ v5\nRoteamento dinâmico LLM            ModelRouter dinâmico                      Circuit breaker estático                  ✅ v5\nLatência caminho simples           50-200ms                                  2-10s                                     ✅ v5\nSeparação dados/IA                 HTTP → Rails (fronteira clara)            SQL direto nos agents                     ✅ v5\nCusto 9º domínio                   Reimplementa compliance (0L real)         0 linhas (herdado)                        ✅ LIA\nLearning Loop                      tracker.py básico (88L)                   1137L + A/B + fairness gate               ✅ LIA\nGuardrails em produção             Hardcoded, requer deploy                  DB editável, efeito imediato              ✅ LIA","autoResize":true,"lineHeight":1.25},{"id":"cmp_footer","type":"text","x":60,"y":5910,"width":2580,"height":57,"angle":0,"strokeColor":"#64748b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":25724234,"version":1,"versionNonce":92559350,"isDeleted":false,"boundElements":null,"updated":1774820769816,"link":null,"locked":false,"text":"Resultado: LIA vence em 6 de 10 dimensões (compliance, consistência, observabilidade, custo marginal, learning, guardrails).\nv5 vence em 4 dimensões (paralelismo, roteamento dinâmico, latência, separação dados/IA). O v5 é mais rápido e mais modular;\na LIA é mais segura e mais completa em compliance.","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Resultado: LIA vence em 6 de 10 dimensões (compliance, consistência, observabilidade, custo marginal, learning, guardrails).\nv5 vence em 4 dimensões (paralelismo, roteamento dinâmico, latência, separação dados/IA). O v5 é mais rápido e mais modular;\na LIA é mais segura e mais completa em compliance.","autoResize":true,"lineHeight":1.25},{"id":"flow_title_bg","type":"rectangle","x":50,"y":5980,"width":2600,"height":30,"angle":0,"strokeColor":"#0369a1","backgroundColor":"#0369a1","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":177289103,"version":1,"versionNonce":844502703,"isDeleted":false,"boundElements":null,"updated":1774820769816,"link":null,"locked":false},{"id":"flow_title","type":"text","x":60,"y":5985,"width":2580,"height":22,"angle":0,"strokeColor":"#ffffff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":346351220,"version":1,"versionNonce":533312529,"isDeleted":false,"boundElements":null,"updated":1774820769816,"link":null,"locked":false,"text":"EXEMPLO REAL: FLUXO DE TRIAGEM DE CANDIDATO — PASSO A PASSO","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"original