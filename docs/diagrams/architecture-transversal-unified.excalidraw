m providers\n• Sem rate limiting por provider no factory","autoResize":true,"lineHeight":1.25},{"id":"p6_s9_v5_con","type":"text","x":1410,"y":11417,"width":1230,"height":57,"angle":0,"strokeColor":"#334155","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":996035792,"version":1,"versionNonce":426466742,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"• Vendor lock-in 100% Gemini — se indisponível, v5 para COMPLETAMENTE\n• Sem DLQ — tasks que falham 3x desaparecem\n• Sem métricas de circuit — impossível saber quantas vezes abriu","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"• Vendor lock-in 100% Gemini — se indisponível, v5 para COMPLETAMENTE\n• Sem DLQ — tasks que falham 3x desaparecem\n• Sem métricas de circuit — impossível saber quantas vezes abriu","autoResize":true,"lineHeight":1.25},{"id":"p6_s10_bg","type":"rectangle","x":50,"y":11509,"width":2600,"height":30,"angle":0,"strokeColor":"#e0f2f1","backgroundColor":"#e0f2f1","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":931201976,"version":1,"versionNonce":91862167,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s10_title","type":"text","x":60,"y":11514,"width":2580,"height":22,"angle":0,"strokeColor":"#00695c","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":166695692,"version":1,"versionNonce":57131547,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"10. APRENDIZADO & ADAPTAÇÃO (Seção 14)","fontSize":16,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"10. APRENDIZADO & ADAPTAÇÃO (Seção 14)","autoResize":true,"lineHeight":1.25},{"id":"p6_s10_narrative","type":"text","x":60,"y":11549,"width":2580,"height":76,"angle":0,"strokeColor":"#334155","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":868956815,"version":1,"versionNonce":314264241,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false,"text":"POR QUE IMPORTA: Learning loop completo diferencia um produto que melhora sozinho de um que exige intervenção manual.\nA LIA tem: feedback → ml_feedback_service → learning_loop_service → ab_testing_service → template_learning_service →\nrouting_learning_service → finetuning_export → model_drift_service. O v5 tem FeedbackTracker + ProactiveDetector — mas\nninguém usa esses dados automaticamente. O sistema v5 é o mesmo no dia 1 e no dia 365.","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"POR QUE IMPORTA: Learning loop completo diferencia um produto que melhora sozinho de um que exige intervenção manual.\nA LIA tem: feedback → ml_feedback_service → learning_loop_service → ab_testing_service → template_learning_service →\nrouting_learning_service → finetuning_export → model_drift_service. O v5 tem FeedbackTracker + ProactiveDetector — mas\nninguém usa esses dados automaticamente. O sistema v5 é o mesmo no dia 1 e no dia 365.","autoResize":true,"lineHeight":1.25},{"id":"p6_s10_lia_pro_bg","type":"rectangle","x":50,"y":11635,"width":1250,"height":125,"angle":0,"strokeColor":"#e2e8f0","backgroundColor":"#e8f5e9","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"roundness":{"type":3},"seed":64823915,"version":1,"versionNonce":996758157,"isDeleted":false,"boundElements":null,"updated":1774820222848,"link":null,"locked":false},{"id":"p6_s10_v5_pro_bg","type":"rectangle","x":1400,"y":11635,"width":1250,"he