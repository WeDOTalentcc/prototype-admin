modules = ["nodejs-20", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["python_gemini_ai_integrations:1.0.0", "python_anthropic_ai_integrations:1.0.0", "jira:1.0.0", "python_openai:1.0.0", "github:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["cargo", "freetype", "glibcLocales", "libiconv", "libyaml", "postgresql", "rustc", "xcodebuild", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "dev-server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "lia-backend"

[[workflows.workflow]]
name = "dev-server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd plataforma-lia && npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "lia-backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "redis-server --daemonize yes 2>/dev/null; (fuser -k -KILL 8001/tcp 2>/dev/null || true); sleep 1; cd lia-agent-system && PYTHONUNBUFFERED=1 python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8001 --reload --reload-include='app/**/*.py' --reload-include='app/**/*.yaml' --reload-exclude='**/__pycache__/**' --reload-exclude='**/*.pyc' --reload-exclude='**/tests/**' --reload-exclude='**/.git/**' --reload-delay=3 2>&1 | tee /tmp/lia-backend-stdout.log"

