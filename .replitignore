# Exclui artefatos de desenvolvimento e backups da imagem de deploy.
# Motivo: o deploy VM tem limite de 8 GiB e monta a imagem a partir do
# filesystem (NÃO usa .gitignore). Nada listado aqui é necessário em runtime.

# Estado interno do agente / Replit (maior peso: ~3.9G)
.local/
.cache/
.config/
.upm/

# Histórico git (não usado em runtime, ~793M)
.git/

# Backups e código legado não publicado neste deploy
ats_api/
ats-api-copia/
onboarding-patches/

# Sandboxes de mockup / canvas (dev-only)
artifacts/
plataforma-lia/mockup-sandbox/

# Documentação e anexos (não usados em runtime)
docs/
attached_assets/

# Testes e eval do backend (não usados em runtime)
lia-agent-system/eval/
lia-agent-system/tests/
lia-agent-system/tests-eval/

# Caches Python
**/__pycache__/
**/*.pyc
**/*.pyo
