'use client'

import { Button } from "@/components/ui/button"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Badge } from "@/components/ui/badge"
import { Switch } from "@/components/ui/switch"
import {
  Plus, Loader2, FileText, Shield,
  RefreshCw, Grid3X3, Zap
} from "lucide-react"
import type { MatrixEntry, MatrixModule } from './types'
import { moduleLabels, moduleIcons, recipientLabels, channelConfig } from './constants'

interface MatrixSectionProps {
  matrixModules: MatrixModule[]
  matrixLoading: boolean
  selectedMatrixModule: string | null
  setSelectedMatrixModule: (module: string | null) => void
  updatingMatrixEntry: string | null
  seedingMatrix: boolean
  fetchMatrixEntries: () => void
  handleSeedMatrix: () => void
  handleToggleMatrixActive: (entry: MatrixEntry) => void
  handleToggleMatrixChannel: (entry: MatrixEntry, channel: string) => void
}

export function MatrixSection({
  matrixModules,
  matrixLoading,
  selectedMatrixModule,
  setSelectedMatrixModule,
  updatingMatrixEntry,
  seedingMatrix,
  fetchMatrixEntries,
  handleSeedMatrix,
  handleToggleMatrixActive,
  handleToggleMatrixChannel
}: MatrixSectionProps) {
  const filteredModules = selectedMatrixModule 
    ? matrixModules.filter(m => m.module === selectedMatrixModule)
    : matrixModules

  const allChannels = ['email', 'whatsapp', 'bell', 'teams', 'chat']

  return (
    <div className="space-y-4">
      <div className="flex items-center justify-between mb-4">
        <div>
          <h3 className="text-sm font-medium text-gray-500 dark:text-gray-400" >
            Matriz de Comunicações
          </h3>
          <p className="text-xs mt-1 text-gray-400 dark:text-gray-500" >
            Configure todos os triggers de comunicação do sistema por módulo
          </p>
        </div>
        <div className="flex items-center gap-2">
          <Button
            variant="ghost"
            size="sm"
            onClick={fetchMatrixEntries}
            disabled={matrixLoading}
          >
            <RefreshCw className={`w-4 h-4 ${matrixLoading ? 'animate-spin' : ''}`} />
          </Button>
          <Button
            variant="outline"
            size="sm"
            onClick={handleSeedMatrix}
            disabled={seedingMatrix || matrixLoading}
          >
            {seedingMatrix ? (
              <Loader2 className="w-4 h-4 mr-2 animate-spin" />
            ) : (
              <Plus className="w-4 h-4 mr-2" />
            )}
            Popular Padrões
          </Button>
        </div>
      </div>

      <div className="flex flex-wrap gap-2 mb-4">
        <Button
          variant={selectedMatrixModule === null ? 'default' : 'outline'}
          size="sm"
          onClick={() => setSelectedMatrixModule(null)}
          className={selectedMatrixModule === null ? 'bg-gray-900 dark:bg-gray-50 hover:bg-gray-800 dark:hover:bg-gray-200 text-white dark:text-gray-900' : ''}
        >
          <Grid3X3 className="w-4 h-4 mr-2" />
          Todos
        </Button>
        {Object.entries(moduleLabels).map(([key, { label, emoji }]) => {
          const ModIcon = moduleIcons[key]
          return (
            <Button
              key={key}
              variant={selectedMatrixModule === key ? 'default' : 'outline'}
              size="sm"
              onClick={() => setSelectedMatrixModule(key)}
              className={selectedMatrixModule === key ? 'bg-gray-900 dark:bg-gray-50 hover:bg-gray-800 dark:hover:bg-gray-200 text-white dark:text-gray-900' : ''}
            >
              {ModIcon && <ModIcon className="w-4 h-4 mr-2" />}
              <span className="mr-1">{emoji}</span>
              {label}
            </Button>
          )
        })}
      </div>

      {matrixLoading && matrixModules.length === 0 ? (
        <div className="flex items-center justify-center py-12">
          <Loader2 className="w-8 h-8 animate-spin text-gray-700 dark:text-gray-300" />
          <span className="ml-3 text-sm text-gray-500 dark:text-gray-400" >
            Carregando matriz...
          </span>
        </div>
      ) : matrixModules.length === 0 ? (
        <Card className="flex flex-col items-center justify-center py-12">
          <Grid3X3 className="w-12 h-12 mb-3 text-gray-400 dark:text-gray-500"  />
          <p className="text-sm font-medium mb-1 text-gray-500 dark:text-gray-400" >
            Nenhuma configuração encontrada
          </p>
          <p className="text-xs mb-4 text-gray-400 dark:text-gray-500" >
            Popule a matriz com os dados padrão para começar
          </p>
          <Button
            size="sm"
            className="bg-gray-900 dark:bg-gray-50 hover:bg-gray-800 dark:hover:bg-gray-200"
            onClick={handleSeedMatrix}
            disabled={seedingMatrix}
          >
            {seedingMatrix ? (
              <Loader2 className="w-4 h-4 mr-2 animate-spin" />
            ) : (
              <Plus className="w-4 h-4 mr-2" />
            )}
            Popular com Dados Padrão
          </Button>
        </Card>
      ) : (
        <div className="space-y-6">
          {filteredModules.map(mod => {
            const ModIcon = moduleIcons[mod.module]
            const modLabel = moduleLabels[mod.module] || { label: mod.label, emoji: '📁' }
            
            return (
              <Card key={mod.module}>
                <CardHeader className="pb-3">
                  <div className="flex items-center justify-between">
                    <div className="flex items-center gap-3">
                      <div className="w-10 h-10 rounded-md flex items-center justify-center bg-gray-100 dark:bg-gray-800">
                        {ModIcon && <ModIcon className="w-5 h-5 text-gray-700 dark:text-gray-300" />}
                      </div>
                      <div>
                        <CardTitle className="text-base flex items-center gap-2">
                          <span>{modLabel.emoji}</span>
                          {modLabel.label}
                        </CardTitle>
                        <p className="text-xs text-gray-400 dark:text-gray-500" >
                          {mod.description || `${mod.totalEntries} triggers configurados`}
                        </p>
                      </div>
                    </div>
                    <Badge variant="outline" className="text-xs">
                      {mod.activeEntries}/{mod.totalEntries} ativos
                    </Badge>
                  </div>
                </CardHeader>
                <CardContent className="pt-0">
                  <div className="space-y-3">
                    {mod.entries.map(entry => {
                      const recipientInfo = recipientLabels[entry.recipientType] || { label: entry.recipientType, color: 'bg-gray-100 text-gray-600' }
                      const isUpdating = updatingMatrixEntry === entry.id
                      
                      return (
                        <div
                          key={entry.id}
 className={`p-4 rounded-md border transition-opacity ${entry.isActive ? 'bg-white' : 'bg-gray-50 dark:bg-gray-800/50 opacity-60'}`}
                          className="border-gray-200 dark:border-gray-700" 
                        >
                          <div className="flex items-start justify-between gap-4">
                            <div className="flex-1 min-w-0">
                              <div className="flex items-center gap-2 mb-1 flex-wrap">
                                <h4 className="font-medium text-sm truncate text-gray-800 dark:text-gray-100" >
                                  {entry.triggerName.replace(/_/g, ' ')}
                                </h4>
                                <Badge className={`text-xs ${recipientInfo.color}`}>
                                  {recipientInfo.label}
                                </Badge>
                                {entry.isAutomatic ? (
                                  <Badge className="text-xs bg-status-success/10 text-status-success dark:bg-status-success/20 dark:text-status-success">
                                    <Zap className="w-3 h-3 mr-1" />
                                    Automático
                                  </Badge>
                                ) : (
                                  <Badge className="text-xs bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400">
                                    Manual
                                  </Badge>
                                )}
                                {entry.requiresApproval && (
                                  <Badge className="text-xs bg-status-warning/10 text-status-warning dark:bg-status-warning/20 dark:text-status-warning">
                                    <Shield className="w-3 h-3 mr-1" />
                                    Requer Aprovação
                                  </Badge>
                                )}
                              </div>
                              {entry.triggerDescription && (
                                <p className="text-xs mb-3 text-gray-400 dark:text-gray-500" >
                                  {entry.triggerDescription}
                                </p>
                              )}
                              
                              <div className="flex items-center gap-2 flex-wrap">
                                <span className="text-xs font-medium text-gray-500 dark:text-gray-400" >
                                  Canais:
                                </span>
                                {allChannels.map(channel => {
                                  const config = channelConfig[channel] || { label: channel, color: 'bg-gray-100 text-gray-500', activeColor: 'bg-gray-200 text-gray-700' }
                                  const isActive = entry.channels.includes(channel)
                                  return (
                                    <button
                                      key={channel}
                                      onClick={() => handleToggleMatrixChannel(entry, channel)}
                                      disabled={isUpdating}
                                      className={`px-2 py-0.5 rounded-md text-xs font-medium transition-colors cursor-pointer ${isActive ? config.activeColor : config.color} ${isUpdating ? 'opacity-50' : 'hover:opacity-80'}`}
                                    >
                                      {config.label}
                                    </button>
                                  )
                                })}
                              </div>

                              {entry.templateId && (
                                <div className="flex items-center gap-2 mt-2">
                                  <span className="text-xs text-gray-400 dark:text-gray-500" >
                                    Template:
                                  </span>
                                  <Badge variant="outline" className="text-xs">
                                    <FileText className="w-3 h-3 mr-1" />
                                    {entry.templateId}
                                  </Badge>
                                </div>
                              )}
                            </div>
                            
                            <div className="flex items-center gap-2">
                              {isUpdating && (
                                <Loader2 className="w-4 h-4 animate-spin text-gray-700 dark:text-gray-300" />
                              )}
                              <Switch
                                checked={entry.isActive}
                                onCheckedChange={() => handleToggleMatrixActive(entry)}
                                disabled={isUpdating}
                              />
                            </div>
                          </div>
                        </div>
                      )
                    })}
                  </div>
                </CardContent>
              </Card>
            )
          })}
        </div>
      )}
    </div>
  )
}
