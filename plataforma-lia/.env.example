# =============================================================================
# Plataforma LIA — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite .env.local (já está no .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# BACKEND API
# URL do backend FastAPI (servidor local ou produção)
# -----------------------------------------------------------------------------
BACKEND_URL=http://127.0.0.1:8000
LIA_BACKEND_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# NEXT_PUBLIC — Variáveis expostas ao browser (client-side)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000

# -----------------------------------------------------------------------------
# WORKOS — Autenticação SSO
# Obtenha em: https://dashboard.workos.com
# -----------------------------------------------------------------------------
WORKOS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WORKOS_CLIENT_ID=client_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/workos/callback
WORKOS_SESSION_SECRET=uma-string-aleatoria-longa-de-pelo-menos-32-chars
WORKOS_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# SEGURANÇA INTERNA
# Token compartilhado entre Next.js e backend FastAPI
# -----------------------------------------------------------------------------
INTERNAL_API_SECRET=token-interno-seguro-aleatorio
SERVICE_API_TOKEN=token-de-servico-seguro-aleatorio

# -----------------------------------------------------------------------------
# ANTHROPIC — IA/LLM (usado pelo backend, não pelo frontend diretamente)
# Obtenha em: https://console.anthropic.com
# -----------------------------------------------------------------------------
AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com

# -----------------------------------------------------------------------------
# SENTRY — Monitoramento de erros (opcional)
# Obtenha em: https://sentry.io
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# FLAGS DE DESENVOLVIMENTO
# -----------------------------------------------------------------------------
# Ativa dados de demonstração (sem backend real)
NEXT_PUBLIC_USE_DEMO_DATA=false

# Ativa painel de debug para UI Actions
NEXT_PUBLIC_ENABLE_UI_ACTIONS_DEBUG=false

# Ativa análise de bundle (gera relatório em .next/analyze/)
ANALYZE=false

# -----------------------------------------------------------------------------
# REPLIT — Auto-configuradas pelo ambiente Replit (não alterar manualmente)
# -----------------------------------------------------------------------------
# REPL_IDENTITY=
# REPLIT_CONNECTORS_HOSTNAME=
# REPLIT_DEV_DOMAIN=
# WEB_REPL_RENEWAL=
