{
  "name": "nextjs-shadcn",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "predev": "rm -rf .next/dev",
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' next dev --turbopack -H 0.0.0.0 -p 5000",
    "dev:turbo": "NODE_OPTIONS='--max-old-space-size=4096' next dev --turbopack -H 0.0.0.0 -p 3000",
    "dev:webpack": "NODE_OPTIONS='--max-old-space-size=4096' next dev -H 0.0.0.0 -p 3000",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' next build --turbopack",
    "build:webpack": "NODE_OPTIONS='--max-old-space-size=4096' next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "NODE_OPTIONS='--max-old-space-size=4096' bunx tsc --noEmit && next lint",
    "format": "bunx biome format --write",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes",
    "diagnostic": "node scripts/run-diagnostic.js",
    "diagnostic:smoke": "node scripts/run-diagnostic.js --stage smoke",
    "diagnostic:critical": "node scripts/run-diagnostic.js --stage critical",
    "diagnostic:report": "node scripts/build-diagnostic-report.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:wizard": "playwright test e2e/tests/wizard/",
    "test:e2e:kanban": "playwright test e2e/tests/kanban/",
    "test:e2e:chat": "playwright test e2e/tests/chat/ --reporter=html",
    "test:e2e:chat:list": "playwright test e2e/tests/chat/ --list",
    "test:e2e:job-creation": "playwright test e2e/tests/job-creation/ --project=desktop-chrome",
    "test:e2e:job-creation:replit": "PLAYWRIGHT_BASE_URL=https://82791557-0b63-4f8d-baed-bba54c6e1fdf-00-32kinhguzv9ak.picard.replit.dev npx playwright test e2e/tests/job-creation/ --reporter=html --project=desktop-chrome",
    "test:eval": "playwright test e2e/tests/lia-capability-eval/ --config=e2e/tests/lia-capability-eval/eval.config.ts",
    "test:eval:domain": "playwright test e2e/tests/lia-capability-eval/ --config=e2e/tests/lia-capability-eval/eval.config.ts",
    "test:audit:chat-format": "vitest run src/lib/__tests__/chat-format.audit.test.ts --reporter=verbose",
    "test": "vitest run --project=unit --project=unit-colocated --project=hooks --project=components",
    "test:watch": "vitest --project=unit --project=unit-colocated --project=hooks --project=components",
    "test:coverage": "vitest run --project=unit --project=unit-colocated --project=hooks --project=components --coverage",
    "test:ui": "vitest --ui --project=unit --project=unit-colocated --project=hooks --project=components",
    "test:all": "vitest run",
    "test:e2e:rail-a": "PLAYWRIGHT_BASE_URL=https://82791557-0b63-4f8d-baed-bba54c6e1fdf-00-32kinhguzv9ak.picard.replit.dev npx playwright test e2e/tests/chat/rail-a-cards.spec.ts --project=desktop-chrome",
    "test:e2e:settings-prefill": "playwright test e2e/tests/settings/prefill-section-handoff.spec.ts --project=desktop-chrome --project=mobile-chrome --reporter=list",
    "generate:api-types": "curl -s http://localhost:8001/openapi.json > /tmp/lia-openapi.json && npx openapi-typescript /tmp/lia-openapi.json -o src/types/api.generated.ts",
    "generate:wizard-types": "python3 ../lia-agent-system/scripts/generate_wizard_types.py",
    "check:wizard-types": "python3 ../lia-agent-system/scripts/generate_wizard_types.py --check",
    "analyze": "ANALYZE=true pnpm build",
    "prepare": "husky || true",
    "lint:chips": "node scripts/check_chip_overrides.mjs",
    "lint:chips:warn": "node scripts/check_chip_overrides.mjs --no-fail",
    "lint:chips:baseline": "node scripts/check_chip_overrides.mjs --baseline",
    "lint:i18n": "python3 scripts/check_i18n_keys.py",
    "lint:i18n:blocking": "python3 scripts/check_i18n_keys.py --blocking",
    "lint:i18n:json": "python3 scripts/check_i18n_keys.py --json",
    "lint:studio-substabs": "python3 scripts/check_no_studio_substabs.py",
    "lint:candidate-axis": "python3 scripts/check_candidate_score_uses_canonical_badge.py && python3 scripts/check_editable_fields_not_lgpd_sensitive.py",
    "lint:candidate-axis:blocking": "python3 scripts/check_candidate_score_uses_canonical_badge.py --blocking && python3 scripts/check_editable_fields_not_lgpd_sensitive.py --blocking",
    "sensor:lia-sync": "python3 scripts/check_lia_field_definitions_sync.py",
    "sensor:lia-sync:blocking": "python3 scripts/check_lia_field_definitions_sync.py --blocking",
    "sensor:tokens": "node scripts/check_canonical_tailwind_tokens.mjs",
    "sensor:tokens:blocking": "node scripts/check_canonical_tailwind_tokens.mjs --blocking",
    "lint:no-conflict-markers": "python3 scripts/check_no_conflict_markers.py"
  },
